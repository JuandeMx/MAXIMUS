        ui_subhr
        echo -e "${CYAN} [3] CAMBIAR PUERTO DEL PANEL WEB${NC}"
        echo -e "${CYAN} [4] ABRIR PANEL WEB${NC}"
        ui_hr
        echo -e "${CYAN} [0] VOLVER${NC}"
        ui_hr
        ui_prompt "Selecciona: " ; read opt_xui

        case $opt_xui in
            1)
                bash /etc/MaximusVpsMx/modules/install_xui.sh
                ;;
            2)
                echo -e "\n${RED}⚠️ Esto eliminará el panel X-UI y todos sus usuarios.${NC}"
