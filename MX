            12) gestor_servicio "CHECKUSER ONLINE" "checkuser" ;;
            13) echo "🔄 Reiniciando red..."; systemctl restart mx-proxy dropbear stunnel4 badvpn mx-slowdns ssh 2>/dev/null; sleep 2 ;;
            0) return ;;
            *) continue ;;
        esac
