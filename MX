# --- SUBMENأڑ DE PROTOCOLOS ---
menu_protocolos() {
    ui_header "A D M I N I S T R A D O R   D E   P R O T O C O L O S"
    # --- DETECCIأ“N DINأپMICA DE PUERTOS Y ESTATUS (Doble Verificaciأ³n) ---

    # SSH (OpenSSH)
    P_SSH=$(grep "^Port" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1)
    [ -z "$P_SSH" ] && P_SSH="22"
    if netstat -tuln 2>/dev/null | grep -q ":${P_SSH} "; then st_ssh="${GREEN}[ON] ${NC}"; else st_ssh="${RED}[OFF]${NC}"; fi

    # Dropbear
    if dpkg -l dropbear 2>/dev/null | grep -q "^ii"; then
        P_DROP=$(grep "DROPBEAR_PORT=" /etc/default/dropbear 2>/dev/null | cut -d= -f2 | tr -d '"' | xargs)
        [ -z "$P_DROP" ] && P_DROP="44"
        if netstat -tuln 2>/dev/null | grep -q ":${P_DROP} "; then st_drop="${GREEN}[ON] ${NC}"; else st_drop="${RED}[OFF]${NC}"; fi
    else
        P_DROP="--"; st_drop="${RED}[OFF]${NC}"
    fi

    # Proxy Python
    if [ -f /etc/systemd/system/mx-proxy.service ]; then
        P_PROXY=$(grep "ExecStart=" /etc/systemd/system/mx-proxy.service 2>/dev/null | awk '{print $NF}')
        P_PROXY="${P_PROXY%%-*}"
        [ -z "$P_PROXY" ] && P_PROXY="80"
        if netstat -tuln 2>/dev/null | grep -q ":${P_PROXY} "; then st_proxy="${GREEN}[ON] ${NC}"; else st_proxy="${RED}[OFF]${NC}"; fi
    else
        P_PROXY="--"; st_proxy="${RED}[OFF]${NC}"
    fi

    # Stunnel (SSL)
    if [ -f /etc/stunnel/stunnel.conf ] && dpkg -l stunnel4 2>/dev/null | grep -q "^ii"; then
        P_STUN=$(grep "accept =" /etc/stunnel/stunnel.conf 2>/dev/null | awk '{print $3}' | head -1)
        [ -z "$P_STUN" ] && P_STUN="443"
        if netstat -tuln 2>/dev/null | grep -q ":${P_STUN} "; then st_stun="${GREEN}[ON] ${NC}"; else st_stun="${RED}[OFF]${NC}"; fi
    else
        P_STUN="--"; st_stun="${RED}[OFF]${NC}"
    fi

    # BadVPN (UDP)
    if [ -f /usr/local/bin/badvpn-udpgw ]; then
        if ps -ef | grep -q "[b]advpn-udpgw"; then
            P_BAD=$(ps -ef | grep badvpn-udpgw | grep -v grep | grep -o ":[0-9]*" | head -1 | tr -d ':')
            [ -z "$P_BAD" ] && P_BAD="7300"
            st_udp="${GREEN}[ON] ${NC}"
        else
            P_BAD="--"; st_udp="${RED}[OFF]${NC}"
        fi
    else
        P_BAD="--"; st_udp="${RED}[OFF]${NC}"
    fi

    # SlowDNS
    systemctl is-active --quiet mx-slowdns && st_dns="${GREEN}[ON] ${NC}" || st_dns="${RED}[OFF]${NC}"
    # WS-EPRO
    systemctl is-active --quiet ws-epro && st_ws="${GREEN}[ON] ${NC}" || st_ws="${RED}[OFF]${NC}"

    # UDP-Custom
    if systemctl is-active --quiet udp-custom 2>/dev/null; then
        P_UDPC="7100-7300"
        st_udpc="${GREEN}[ON] ${NC}"
    else
        P_UDPC="--"; st_udpc="${RED}[OFF]${NC}"
    fi

    # Hysteria v2
    if [ -f /etc/hysteria/hysteria ]; then
        if systemctl is-active --quiet hysteria 2>/dev/null; then
            P_HY="2000-5000"
            st_udph="${GREEN}[ON] ${NC}"
        else
            P_HY="--"; st_udph="${RED}[OFF]${NC}"
        fi
    else
        P_HY="--"; st_udph="${RED}[OFF]${NC}"
    fi

    # OpenVPN
    P_OVPN="--"
    if [ -f /etc/openvpn/server/server.conf ]; then
        OVPN_PORT=$(grep -E '^port ' /etc/openvpn/server/server.conf 2>/dev/null | awk '{print $2}' | head -1)
        OVPN_PROTO=$(grep -E '^proto ' /etc/openvpn/server/server.conf 2>/dev/null | awk '{print $2}' | head -1)
        [ -z "$OVPN_PORT" ] && OVPN_PORT="1194"
        [ -z "$OVPN_PROTO" ] && OVPN_PROTO="udp"
        P_OVPN="${OVPN_PORT}/${OVPN_PROTO}"
        systemctl is-active --quiet openvpn-server@server 2>/dev/null && st_ovpn="${GREEN}[ON] ${NC}" || st_ovpn="${RED}[OFF]${NC}"
    else
        st_ovpn="${RED}[OFF]${NC}"
    fi

    st_chk="${GREEN}[ON] ${NC}"
    if systemctl is-active --quiet x-ui 2>/dev/null; then st_xui="${GREEN}[ON] ${NC}"; else st_xui="${RED}[OFF]${NC}"; fi

    # Resumen (compacto)
    echo -e " ${CYAN}SSH:${WHITE} $P_SSH  ${CYAN}DROB:${WHITE} $P_DROP  ${CYAN}PROXY:${WHITE} $P_PROXY  ${CYAN}SSL:${WHITE} $P_STUN${NC}"
    echo -e " ${CYAN}UDPG:${WHITE} $P_BAD  ${CYAN}UDPC:${WHITE} $P_UDPC  ${CYAN}HYST:${WHITE} $P_HY  ${CYAN}OVPN:${WHITE} $P_OVPN${NC}"
    ui_hr
    printf "  ${CYAN}[1] ${WHITE}%-15s %b  ${CYAN}[7] ${WHITE}%-15s %b\n" "SSH" "$st_ssh" "OPENVPN" "$st_ovpn"
    printf "  ${CYAN}[2] ${WHITE}%-15s %b  ${CYAN}[8] ${WHITE}%-15s %b\n" "DROPBEAR" "$st_drop" "SLOWDNS" "$st_dns"
    printf "  ${CYAN}[3] ${WHITE}%-15s %b  ${CYAN}[9] ${WHITE}%-15s %b\n" "WS-EPRO" "$st_ws" "UDP-CUSTOM" "$st_udpc"
    printf "  ${CYAN}[4] ${WHITE}%-15s %b  ${CYAN}[10] ${WHITE}%-15s %b\n" "PYTHON PROXY" "$st_proxy" "HYSTERIA v2" "$st_udph"
    printf "  ${CYAN}[5] ${WHITE}%-15s %b  ${CYAN}[11] ${WHITE}%-15s %b\n" "STUNNEL4" "$st_stun" "PANEL X-UI" "$st_xui"
    printf "  ${CYAN}[6] ${WHITE}%-15s %b  ${CYAN}[12] ${WHITE}%-15s %b\n" "BADVPN" "$st_udp" "CHECKUSER" "$st_chk"
    ui_subhr
    echo -e "  ${CYAN}[13]>${WHITE} REINICIAR TODOS LOS SERVICIOS${NC}"
    ui_hr
    echo -e "  ${WHITE}[0] VOLVER AL MENأڑ PRINCIPAL${NC}"
    ui_hr
    ui_prompt " Selecciona una opciأ³n: "
    read opt_prot
    
    case $opt_prot in
        1) gestor_servicio "SSH" "ssh" ;;
        2) gestor_servicio "DROPBEAR" "dropbear" ;;
        3) gestor_servicio "WS-EPRO" "ws-epro" ;;
        4) gestor_servicio "SOCKS PYTHON" "mx-proxy" ;;
        5) gestor_servicio "STUNNEL (SSL)" "stunnel4" ;;
        6) gestor_servicio "BADVPN-UDPGW" "badvpn" ;;
        7) gestor_servicio "OPENVPN" "openvpn" ;;
        8) sub_slowdns ;;
        9) gestor_servicio "UDP-CUSTOM" "udp-custom" ;;
        10) sub_hysteria ; menu_protocolos ;;
        11) sub_xui ; menu_protocolos ;;
        12) gestor_servicio "CHECKUSER ONLINE" "checkuser" ;;
        13)
            echo "ًں”„ Reiniciando toda la red..."
            systemctl restart mx-proxy dropbear stunnel4 badvpn mx-slowdns ssh 2>/dev/null
            sleep 2; menu_protocolos ;;
        0) main_menu ;;
        *) menu_protocolos ;;
    esac
}

