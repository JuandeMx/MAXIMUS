                if [[ "$conf_del" == "s" || "$conf_del" == "S" ]]; then
                    echo -e "${YELLOW}[+] Deteniendo y limpiando X-UI...${NC}"
                    systemctl stop x-ui 2>/dev/null
                    systemctl disable x-ui 2>/dev/null
                    rm -rf /usr/local/x-ui
                    rm -rf /etc/x-ui
