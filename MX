        systemctl is-active --quiet hysteria && hy_st="${GREEN}[ON]${NC}" || hy_st="${RED}[OFF]${NC}"
        hy_port=$(grep 'listen:' /etc/hysteria/config.yaml 2>/dev/null | grep -o '[0-9]*' | head -1)
        [ -z "$hy_port" ] && hy_port="443"

        echo -e " Estatus: $hy_st   Puerto: ${WHITE}$hy_port${NC}"
        ui_subhr
        echo -e "${CYAN} [1] CREAR USUARIO HYSTERIA${NC}"
        echo -e "${CYAN} [2] ELIMINAR / RENOVAR USUARIO${NC}"
        echo -e "${CYAN} [3] LISTAR CUENTAS ACTIVAS${NC}"
        ui_subhr
        echo -e "${CYAN} [4] MONITOR DE CONEXIONES${NC}"
        echo -e "${CYAN} [5] CONFIGURACIÓN GLOBAL (Puerto/Obfs)${NC}"
        echo -e "${CYAN} [6] INSTALAR / REINSTALAR MOTOR H2${NC}"
        ui_hr
        echo -e "${CYAN} [0] VOLVER${NC}"
        ui_hr
        ui_prompt "Selecciona: " ; read opt_hy

        case $opt_hy in
            1)
                echo -e "\n${YELLOW}▶ Nuevo Usuario Hysteria${NC}"
                read -p " Nombre de Usuario: " hy_user
                read -p " Contraseña/Key: " hy_pass
                read -p " Días de Duración: " hy_days
                read -p " Límite Bajada (Mbps): " hy_down
                read -p " Límite Subida (Mbps): " hy_up
                
                exp_date=$(date -d "+$hy_days days" +%Y-%m-%d)
                # user:pass:expiry:up_m:down_m
                echo "$hy_user:$hy_pass:$exp_date:$hy_up:$hy_down" >> /etc/MaximusVpsMx/hysteria_users.db
                
                # Generar enlace hy2
                server_ip=$(wget -qO- ipv4.icanhazip.com)
                obfs_val=$(grep 'password:' /etc/hysteria/config.yaml | tail -1 | awk '{print $NF}')
                echo -e "\n${GREEN}✅ Usuario $hy_user Creado Correctamente.${NC}"
                echo -e "${CYAN}Expiración: $exp_date${NC}"
                echo -e "${WHITE}-------------------------------------------------------${NC}"
                echo -e "${YELLOW}📋 ENLACE HY2:${NC}"
                echo -e "${WHITE}hy2://$hy_pass@$server_ip:$hy_port?insecure=1&sni=bing.com&obfs=salamander&obfs-password=$obfs_val#$hy_user${NC}"
                echo -e "${WHITE}-------------------------------------------------------${NC}"
                read -p "Presiona Enter..." ;;
            2)
                echo -e "\n${YELLOW}▶ Eliminar Usuario Hysteria${NC}"
                read -p " Nombre a eliminar: " user_del
                sed -i "/^$user_del:/d" /etc/MaximusVpsMx/hysteria_users.db
                echo -e "${RED}✅ Usuario $user_del eliminado.${NC}"; sleep 2 ;;
            3)
                echo -e "\n${YELLOW}▶ Cuentas Activas Hysteria v2${NC}"
                echo -e "${CYAN}-------------------------------------------------------${NC}"
                printf "${WHITE}%-12s | %-12s | %-10s | %-10s\n${NC}" "USUARIO" "EXPIRACIÓN" "LIMIT UP" "LIMIT DOWN"
                echo -e "${CYAN}-------------------------------------------------------${NC}"
                while IFS=: read -r huser hpass hexp hup hdown; do
                    printf "%-12s | %-12s | %-10s | %-10s\n" "$huser" "$hexp" "${hup}M" "${hdown}M"
                done < /etc/MaximusVpsMx/hysteria_users.db
                ui_pause ;;
            4)
                echo -e "\n${YELLOW}▶ Monitor Hysteria (Presiona Ctrl+C para salir)...${NC}"
                tail -f /var/log/MaximusVpsMx/hysteria_auth.log &
                journalctl -u hysteria -f
                kill %1 2>/dev/null ;;
            5)
                echo -e "\n${YELLOW}▶ Configuración Global Hysteria${NC}"
                nano /etc/hysteria/config.yaml
                systemctl restart hysteria 2>/dev/null ;;
            6)
                bash /etc/MaximusVpsMx/modules/install_hysteria.sh ;;
            0) break ;;
        esac
    done
}

# --- SUBMENÚ DE PROTOCOLOS ---
menu_protocolos() {
    ui_header "A D M I N I S T R A D O R   D E   P R O T O C O L O S"
    # --- DETECCIÓN DINÁMICA DE PUERTOS Y ESTATUS (Doble Verificación) ---

    # SSH (OpenSSH)
    P_SSH=$(grep "^Port" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1)
    [ -z "$P_SSH" ] && P_SSH="22"
    if netstat -tuln 2>/dev/null | grep -q ":${P_SSH} "; then st_ssh="${GREEN}[ON]${NC}"; else st_ssh="${RED}[OFF]${NC}"; fi

    # Dropbear
    if dpkg -l dropbear 2>/dev/null | grep -q "^ii"; then
        P_DROP=$(grep "DROPBEAR_PORT=" /etc/default/dropbear 2>/dev/null | cut -d= -f2 | tr -d '"' | xargs)
        [ -z "$P_DROP" ] && P_DROP="44"
        if netstat -tuln 2>/dev/null | grep -q ":${P_DROP} "; then st_drop="${GREEN}[ON]${NC}"; else st_drop="${RED}[OFF]${NC}"; fi
    else
        P_DROP="--"; st_drop="${RED}[OFF]${NC}"
    fi

    # Proxy Python
    if [ -f /etc/systemd/system/mx-proxy.service ]; then
        P_PROXY=$(grep "ExecStart=" /etc/systemd/system/mx-proxy.service 2>/dev/null | awk '{print $NF}')
        P_PROXY="${P_PROXY%%-*}"
        [ -z "$P_PROXY" ] && P_PROXY="80"
        if netstat -tuln 2>/dev/null | grep -q ":${P_PROXY} "; then st_proxy="${GREEN}[ON]${NC}"; else st_proxy="${RED}[OFF]${NC}"; fi
    else
        P_PROXY="--"; st_proxy="${RED}[OFF]${NC}"
    fi

    # Stunnel (SSL)
    if [ -f /etc/stunnel/stunnel.conf ] && dpkg -l stunnel4 2>/dev/null | grep -q "^ii"; then
        P_STUN=$(grep "accept =" /etc/stunnel/stunnel.conf 2>/dev/null | awk '{print $3}' | head -1)
        [ -z "$P_STUN" ] && P_STUN="443"
        if netstat -tuln 2>/dev/null | grep -q ":${P_STUN} "; then st_stun="${GREEN}[ON]${NC}"; else st_stun="${RED}[OFF]${NC}"; fi
    else
        P_STUN="--"; st_stun="${RED}[OFF]${NC}"
    fi

    # BadVPN (UDP)
    if [ -f /usr/local/bin/badvpn-udpgw ]; then
        if ps -ef | grep -q "[b]advpn-udpgw"; then
            P_BAD=$(ps -ef | grep badvpn-udpgw | grep -v grep | grep -o ":[0-9]*" | head -1 | tr -d ':')
            [ -z "$P_BAD" ] && P_BAD="7300"
            st_udp="${GREEN}[ON]${NC}"
        else
            P_BAD="--"; st_udp="${RED}[OFF]${NC}"
        fi
    else
        P_BAD="--"; st_udp="${RED}[OFF]${NC}"
    fi

    # SlowDNS
    systemctl is-active --quiet mx-slowdns && st_dns="${GREEN}[ON]${NC}" || st_dns="${RED}[OFF]${NC}"
    # WS-EPRO
    systemctl is-active --quiet ws-epro && st_ws="${GREEN}[ON]${NC}" || st_ws="${RED}[OFF]${NC}"

    # UDP-Custom
    if [ -f /root/udp/udp-custom ]; then
        if ps -ef | grep -q "[u]dp-custom"; then
            P_UDPC="1-65535"
            st_udpc="${GREEN}[ON]${NC}"
        else
            P_UDPC="--"; st_udpc="${RED}[OFF]${NC}"
        fi
    else
        P_UDPC="--"; st_udpc="${RED}[OFF]${NC}"
    fi

    # Hysteria v2
    if [ -f /etc/hysteria/hysteria ]; then
        if ps -ef | grep -q "[h]ysteria"; then
            P_HY=$(grep 'listen:' /etc/hysteria/config.yaml 2>/dev/null | grep -o '[0-9]*')
            [ -z "$P_HY" ] && P_HY="443"
            st_udph="${GREEN}[ON]${NC}"
        else
            P_HY="--"; st_udph="${RED}[OFF]${NC}"
        fi
    else
        P_HY="--"; st_udph="${RED}[OFF]${NC}"
    fi

    # OpenVPN
    P_OVPN="--"
    if [ -f /etc/openvpn/server/server.conf ]; then
        OVPN_PORT=$(grep -E '^port ' /etc/openvpn/server/server.conf 2>/dev/null | awk '{print $2}' | head -1)
        OVPN_PROTO=$(grep -E '^proto ' /etc/openvpn/server/server.conf 2>/dev/null | awk '{print $2}' | head -1)
        [ -z "$OVPN_PORT" ] && OVPN_PORT="1194"
        [ -z "$OVPN_PROTO" ] && OVPN_PROTO="udp"
        P_OVPN="${OVPN_PORT}/${OVPN_PROTO}"
        systemctl is-active --quiet openvpn-server@server 2>/dev/null && st_ovpn="${GREEN}[ON]${NC}" || st_ovpn="${RED}[OFF]${NC}"
    else
        st_ovpn="${RED}[OFF]${NC}"
    fi

    st_squid="${RED}[OFF]${NC}"; st_chk="${GREEN}[ON]${NC}"
    st_atken="${RED}[OFF]${NC}"; st_file="${RED}[OFF]${NC}"
    if systemctl is-active --quiet x-ui 2>/dev/null; then st_xui="${GREEN}[ON]${NC}"; else st_xui="${RED}[OFF]${NC}"; fi
    st_sshgo="${RED}[OFF]${NC}"; st_wg="${RED}[OFF]${NC}"

    # Resumen (ordenado)
    echo -e " ${CYAN}SSH:${WHITE} $P_SSH  ${CYAN}DROB:${WHITE} $P_DROP  ${CYAN}PROXY:${WHITE} $P_PROXY  ${CYAN}SSL:${WHITE} $P_STUN${NC}"
    echo -e " ${CYAN}UDPG:${WHITE} $P_BAD  ${CYAN}UDPC:${WHITE} $P_UDPC  ${CYAN}HYST:${WHITE} $P_HY  ${CYAN}OVPN:${WHITE} $P_OVPN${NC}"
    ui_hr
    printf "  ${CYAN}[1] ${WHITE}%-15s %b  ${CYAN}[10] ${WHITE}%-15s %b\n" "SSH" "$st_ssh" "SQUID" "$st_squid"
    printf "  ${CYAN}[2] ${WHITE}%-15s %b  ${CYAN}[11] ${WHITE}%-15s %b\n" "DROPBEAR" "$st_drop" "OPENVPN" "$st_ovpn"
    printf "  ${CYAN}[3] ${WHITE}%-15s %b  ${CYAN}[12] ${WHITE}%-15s %b\n" "PYTHON PROXY" "$st_proxy" "CHECKUSER" "$st_chk"
    printf "  ${CYAN}[4] ${WHITE}%-15s %b  ${CYAN}[13] ${WHITE}%-15s %b\n" "STUNNEL4" "$st_stun" "ATKEN/HASH" "$st_atken"
    printf "  ${CYAN}[5] ${WHITE}%-15s %b  ${CYAN}[14] ${WHITE}%-15s %b\n" "SLOWDNS" "$st_dns" "FILEBROWSER" "$st_file"
    printf "  ${CYAN}[6] ${WHITE}%-15s %b  ${CYAN}[15] ${WHITE}%-15s %b\n" "WS-EPRO" "$st_ws" "PANEL X-UI" "$st_xui"
    printf "  ${CYAN}[7] ${WHITE}%-15s %b  ${CYAN}[16] ${WHITE}%-15s %b\n" "UDP-CUSTOM" "$st_udpc" "SSHGO" "$st_sshgo"
    printf "  ${CYAN}[8] ${WHITE}%-15s %b  ${CYAN}[17] ${WHITE}%-15s %b\n" "HYSTERIA v2" "$st_udph" "WIREGUARD" "$st_wg"
    printf "  ${CYAN}[9] ${WHITE}%-15s %b  ${CYAN}[18] ${WHITE}%-15s %b\n" "BADVPN" "$st_udp" "REINICIAR T." ""
    ui_hr
    echo -e "  ${WHITE}[0] VOLVER AL MENÚ PRINCIPAL${NC}"
    ui_hr
    ui_prompt " Selecciona una opción: "
    read opt_prot
    
    case $opt_prot in
        1) gestor_servicio "SSH" "ssh" ;;
        2) gestor_servicio "DROPBEAR" "dropbear" ;;
        3) gestor_servicio "SOCKS PYTHON" "mx-proxy" ;;
        4) gestor_servicio "STUNNEL (SSL)" "stunnel4" ;;
        5) sub_slowdns ;;
        6) gestor_servicio "WS-EPRO" "ws-epro" ;;
        7) gestor_servicio "UDP-CUSTOM" "udp-custom" ;;
        8) sub_hysteria ; menu_protocolos ;;
        9) gestor_servicio "BADVPN-UDPGW" "badvpn" ;;
        10) gestor_servicio "SQUID" "squid" ;;
        11) gestor_servicio "OPENVPN" "openvpn" ;;
        12) gestor_servicio "CHECKUSER ONLINE" "checkuser" ;;
        13) gestor_servicio "ATKEN AND HASH" "atken" ;;
        14) gestor_servicio "FILEBROWSER" "filebrowser" ;;
        15) sub_xui ; menu_protocolos ;;
        16) gestor_servicio "SSHGO" "sshgo" ;;
        17) gestor_servicio "WIREGUARD" "wireguard" ;;
        18)
            echo "🔄 Reiniciando toda la red..."
            systemctl restart mx-proxy dropbear stunnel4 badvpn mx-slowdns ssh 2>/dev/null
            sleep 2; menu_protocolos ;;
        0) main_menu ;;
        *) menu_protocolos ;;
    esac
}

# --- SUBMENÚ DE SISTEMA ---
menu_sistema() {
    ui_header "H E R R A M I E N T A S   Y   S I S T E M A"
    ufw status | grep -q "active" && fw_st="${GREEN}[Activo]${NC}" || fw_st="${RED}[Inactivo]${NC}"
    crontab -l 2>/dev/null | grep -q "cloudflare-ddns" && cf_st="${GREEN}[Activo]${NC}" || cf_st="${RED}[Inactivo]${NC}"

    echo -e "  ${CYAN}[1]>${WHITE} Optimizar VPS (Limpiar RAM y Caché)${NC}"
    echo -e "  ${CYAN}[2]>${WHITE} Editor de Banner Global (SSH/Issue)${NC}"
    echo -e "  ${CYAN}[3]>${WHITE} Respaldar Cuentas Localmente${NC}"
    echo -e "  ${CYAN}[4]>${WHITE} Monitor de Tráfico (vnstat)${NC}"
    ui_subhr
    echo -e "  ${CYAN}[5]>${WHITE} Firewall UFW Config          | $fw_st${NC}"
    echo -e "  ${CYAN}[7]>${WHITE} PANEL WEB (Premium Edition)  | ${GREEN}[OFF]${NC}"
    ui_hr
    echo -e "  ${WHITE}[0] VOLVER AL MENÚ PRINCIPAL${NC}"
    ui_hr
    ui_prompt " Selecciona una opción: "
    read opt_sys
    
    case $opt_sys in
        1)
            echo -e "\n${YELLOW}▶ Iniciando Limpieza Profunda y Optimización...${NC}"
            
            # 1. Limpieza de Memoria RAM
            echo -ne "${CYAN}[+] Liberando Memoria RAM...${NC}"
            sync; echo 3 > /proc/sys/vm/drop_caches
            swapoff -a && swapon -a
            echo -e " ${GREEN}[OK]${NC}"

            # 2. Limpieza de Logs del Sistema (Journald)
            echo -ne "${CYAN}[+] Purgando Journald (Semanas previas)...${NC}"
            journalctl --vacuum-time=1d > /dev/null 2>&1
            echo -e " ${GREEN}[OK]${NC}"

            # 3. Limpieza de Caché APT
            echo -ne "${CYAN}[+] Limpiando caché de paquetes APT...${NC}"
            apt-get clean > /dev/null 2>&1
            echo -e " ${GREEN}[OK]${NC}"

            # 4. Super Limpieza de Logs (Archivos antiguos y rotados)
            echo -ne "${CYAN}[+] Eliminando historiales de log (.gz, .1, .log.*)...${NC}"
            find /var/log -type f -name "*.[0-9]" -delete > /dev/null 2>&1
            find /var/log -type f -name "*.gz" -delete > /dev/null 2>&1
            find /var/log -type f -name "*.log.*" -delete > /dev/null 2>&1
            
            # Vaciar los logs activos
            find /var/log -type f -name "*.log" -exec truncate -s 0 {} + > /dev/null 2>&1
            rm -rf /var/log/MaximusVpsMx/* 2>/dev/null
            echo -e " ${GREEN}[OK]${NC}"

            echo -e "\n${GREEN}✅ VPS OPTIMIZADO: Se han liberado GB de espacio en disco.${NC}"
            sleep 2; menu_sistema ;;
        2)
            echo -e "\n${YELLOW}▶ Ingrese nuevo texto HTML para el Banner (Ctrl+O para guardar, Ctrl+X para salir)${NC}"
            sleep 3
            nano /etc/issue.net
            menu_sistema ;;
        3)
            echo -e "\n${YELLOW}▶ Generando Backup...${NC}"
            tar -cvf /root/users_backup.tar /etc/passwd /etc/shadow 2>/dev/null
            echo -e "${GREEN}✅ Guardado en /root/users_backup.tar${NC}"
            sleep 2; menu_sistema ;;
        4)
            echo -e "\n${YELLOW}▶ Tráfico de Red (Mes actual)${NC}"
            vnstat -m
            ui_pause ; menu_sistema ;;
        5)
            echo -e "\n${YELLOW}▶ Administrador de Firewall UFW${NC}"
            read -p "¿Qué deseas hacer? [1=Activar Seguro, 2=Desactivar]: " actf
            if [ "$actf" == "1" ]; then
                echo "Permitiendo puertos críticos..."
                ufw allow 22/tcp 2>/dev/null; ufw allow 44/tcp 2>/dev/null; ufw allow 80/tcp 2>/dev/null; ufw allow 443/tcp 2>/dev/null; ufw allow 7300/udp 2>/dev/null
                ufw --force enable
                echo -e "${GREEN}✅ Firewall Activado y Blindado.${NC}"
            elif [ "$actf" == "2" ]; then
                ufw disable
                echo -e "${RED}⚠️ Firewall Apagado.${NC}"
            fi
            sleep 2; menu_sistema ;;
        6)
            ui_header "CLOUDFLARE DDNS"
            echo -e "${GREEN} [1] Configurar Credenciales de Cloudflare${NC}"
            echo -e "${GREEN} [2] Activar DDNS (Cada 5 minutos)${NC}"
            echo -e "${RED} [3] Desactivar DDNS${NC}"
            echo -e "${YELLOW} [4] Forzar Comprobación AHORA${NC}"
            echo -e "${YELLOW} [5] Ver Log de Cambios de IP${NC}"
            echo -e "${YELLOW} [6] Ver Configuración Actual${NC}"
            echo -e "${RED} [0] Volver${NC}"
            read -p "Opción DDNS: " opt_cf

            case $opt_cf in
                1)
                    echo -e "\n${YELLOW}▶ Configurar Cloudflare DDNS${NC}"
                    echo -e "${WHITE}Necesitas los siguientes datos de tu cuenta Cloudflare:${NC}"
                    echo -e "${CYAN}(Encuéntralos en: dash.cloudflare.com → API Tokens)${NC}\n"
                    read -p " 🔑 API Token: " cf_token
                    read -p " 🌐 Zone ID: " cf_zone
                    read -p " 📛 Dominio (ej: vpsmx.tudominio.com): " cf_domain
                    
                    cat > /etc/MaximusVpsMx/cloudflare.conf << CFEOF
# Cloudflare DDNS Config - MaximusVpsMx
CF_API_TOKEN="$cf_token"
CF_ZONE_ID="$cf_zone"
CF_RECORD_NAME="$cf_domain"
CFEOF
                    chmod 600 /etc/MaximusVpsMx/cloudflare.conf
                    echo -e "\n${GREEN}✅ Credenciales guardadas de forma segura.${NC}"
                    sleep 2; menu_sistema ;;
                2)
                    if [ ! -f /etc/MaximusVpsMx/cloudflare.conf ]; then
                        echo -e "${RED}❌ Primero configura las credenciales (Opción 1).${NC}"
                        sleep 2; menu_sistema
                        return
                    fi
                    chmod +x /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                    # Agregar al cron cada 5 minutos
                    (crontab -l 2>/dev/null | grep -v "cloudflare-ddns"; echo "*/5 * * * * /etc/MaximusVpsMx/modules/cloudflare-ddns.sh") | crontab -
                    # Ejecutar una vez inmediatamente
                    /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                    echo -e "${GREEN}✅ DDNS Activado. Comprobará tu IP cada 5 minutos.${NC}"
                    sleep 2; menu_sistema ;;
                3)
                    crontab -l 2>/dev/null | grep -v "cloudflare-ddns" | crontab -
                    echo -e "${RED}⚠️ DDNS Desactivado. Ya no se comprobará la IP.${NC}"
                    sleep 2; menu_sistema ;;
                4)
                    echo -e "\n${YELLOW}▶ Ejecutando comprobación manual...${NC}"
                    if [ -f /etc/MaximusVpsMx/modules/cloudflare-ddns.sh ]; then
                        /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                        echo -e "${GREEN}✅ Comprobación completada.${NC}"
                    else
                        echo -e "${RED}❌ Script no encontrado.${NC}"
                    fi
                    sleep 2; menu_sistema ;;
                5)
                    echo -e "\n${YELLOW}▶ Últimos cambios de IP registrados:${NC}"
                    if [ -f /var/log/MaximusVpsMx/cloudflare-ddns.log ]; then
                        tail -20 /var/log/MaximusVpsMx/cloudflare-ddns.log
                    else
                        echo -e "${RED}No hay logs aún.${NC}"
                    fi
                    ui_pause ; menu_sistema ;;
                6)
                    echo -e "\n${YELLOW}▶ Configuración Actual:${NC}"
                    if [ -f /etc/MaximusVpsMx/cloudflare.conf ]; then
                        source /etc/MaximusVpsMx/cloudflare.conf
                        echo -e " Token: ${GREEN}${CF_API_TOKEN:0:8}...****${NC}"
                        echo -e " Zone:  ${GREEN}$CF_ZONE_ID${NC}"
                        echo -e " Dominio: ${GREEN}$CF_RECORD_NAME${NC}"
                        echo -e " IP Actual: ${CYAN}$(curl -s https://api.ipify.org)${NC}"
                    else
                        echo -e "${RED}No configurado aún.${NC}"
                    fi
                    ui_pause ; menu_sistema ;;
                5)
                    sub_webpanel ;;
                6)
                    sub_webpanel ;;
                *) menu_sistema ;;
            esac
            ;;
        99)
            echo -e "\n${RED}================ ¡¡PELIGRO!! ================${NC}"
            read -p "¿Estás 100% seguro de destruir MaximusVpsMx? [S/N]: " desc
            if [[ "$desc" == "S" || "$desc" == "s" ]]; then
                echo -e "${RED}🔥 INICIANDO PURGA MASIVA...${NC}"
                systemctl stop stunnel4 dropbear mx-proxy badvpn 2>/dev/null
                killall -9 stunnel4 dropbear python3 badvpn-udpgw 2>/dev/null
                rm -rf /etc/MaximusVpsMx
                rm -f /usr/local/bin/MX
                rm -f /etc/systemd/system/mx-proxy.service
                rm -f /etc/systemd/system/badvpn.service
                apt-get purge stunnel4 dropbear -y 2>/dev/null
                systemctl daemon-reload
                echo -e "${GREEN}✅ VUELO COMPLETADO. El servidor vuelve a ser de fábrica.${NC}"
                exit
            else
                menu_sistema
            fi
            ;;
        0) main_menu ;;
        *) menu_sistema ;;
    esac
}

# --- SUBMENÚ DE REINSTALACIÓN / ACTUALIZACIÓN ---
menu_mantenimiento() {
    ui_header "MANTENIMIENTO Y ACTUALIZACIÓN"
    echo -e "  ${CYAN}[1]>${WHITE} ACTUALIZACIÓN INTELIGENTE (Mantiene Datos)${NC}"
    echo -e "      ${WHITE}→ Respalda usuarios y configuraciones.${NC}"
    echo -e "  ${CYAN}[2]>${RED} REINSTALACIÓN LIMPIA (Borra Todo)${NC}"
    echo -e "      ${WHITE}→ Deja el panel como nuevo de fábrica.${NC}"
    ui_subhr
    echo -e "  ${CYAN}[0]${WHITE} Volver al Menú Principal${NC}"
    ui_hr
    ui_prompt " Selecciona una opción: "
    read mant_opt

    case $mant_opt in
        1)
            echo -e "\n${YELLOW}▶ Iniciando Actualización Inteligente...${NC}"
            URL_REPO="https://github.com/JuandeMx/MAXIMUS.git"
            TEMP_DIR="/tmp/MaximusVpsMx_temp"

            echo -e "${CYAN}[+] Descargando última versión de GitHub...${NC}"
            rm -rf "$TEMP_DIR" 2>/dev/null
            if git clone "$URL_REPO" "$TEMP_DIR"; then
                echo -e "${GREEN}[OK] Descarga exitosa.${NC}"
            else
                echo -e "${RED}❌ ERROR: No se pudo conectar con GitHub.${NC}"
                echo -e "${YELLOW}Tu panel actual no ha sido modificado.${NC}"
                ui_pause
                return 1
            fi

            echo -e "${CYAN}[+] Creando respaldo de datos vitales...${NC}"
            mkdir -p /tmp/MX_BACKUP
            [ -f /etc/MaximusVpsMx/users.db ] && cp /etc/MaximusVpsMx/users.db /tmp/MX_BACKUP/
            [ -f /etc/MaximusVpsMx/cloudflare.conf ] && cp /etc/MaximusVpsMx/cloudflare.conf /tmp/MX_BACKUP/
            [ -f /etc/MaximusVpsMx/slowdns/ns-domain.conf ] && cp /etc/MaximusVpsMx/slowdns/ns-domain.conf /tmp/MX_BACKUP/
            [ -f /etc/stunnel/stunnel.pem ] && cp /etc/stunnel/stunnel.pem /tmp/MX_BACKUP/
            [ -f /etc/default/dropbear ] && cp /etc/default/dropbear /tmp/MX_BACKUP/

            echo -e "${CYAN}[+] Reemplazando archivos del sistema...${NC}"
            systemctl stop stunnel4 dropbear mx-proxy badvpn mx-slowdns 2>/dev/null
            rm -rf /etc/MaximusVpsMx
            rm -f /usr/local/bin/MX

            echo -e "${CYAN}[+] Ejecutando instalador...${NC}"
            cd "$TEMP_DIR" && chmod +x install.sh && bash install.sh

            echo -e "${CYAN}[+] Restaurando respaldo de datos...${NC}"
            [ -f /tmp/MX_BACKUP/users.db ] && cp /tmp/MX_BACKUP/users.db /etc/MaximusVpsMx/
            [ -f /tmp/MX_BACKUP/cloudflare.conf ] && cp /tmp/MX_BACKUP/cloudflare.conf /etc/MaximusVpsMx/
            [ -f /tmp/MX_BACKUP/ns-domain.conf ] && cp /tmp/MX_BACKUP/ns-domain.conf /etc/MaximusVpsMx/slowdns/
            [ -f /tmp/MX_BACKUP/stunnel.pem ] && cp /tmp/MX_BACKUP/stunnel.pem /etc/stunnel/
            [ -f /tmp/MX_BACKUP/dropbear ] && cp /tmp/MX_BACKUP/dropbear /etc/default/

            rm -rf "$TEMP_DIR" /tmp/MX_BACKUP
            echo -e "\n${GREEN}✅ ACTUALIZACIÓN COMPLETADA EXITOSAMENTE.${NC}"
            echo -e "${YELLOW}Presiona Enter para volver a iniciar el panel...${NC}"
            read
            MX
            exit
            ;;
        2)
            echo -e "\n${RED}⚠️ REINSTALACION LIMPIA SELECCIONADA${NC}"
            read -p "¿Estás 100% seguro de borrar TODO? [S/N]: " conf_clean
            if [[ "$conf_clean" == "S" || "$conf_clean" == "s" ]]; then
                purgar_sistema_total
                
                cd /tmp || exit
                echo -e "${CYAN}[+] Instalando versión limpia de GitHub...${NC}"
                rm -rf /tmp/MaximusVpsMx
                apt-get install -y git 2>/dev/null
                git clone https://github.com/JuandeMx/MAXIMUS.git /tmp/MaximusVpsMx
                cd /tmp/MaximusVpsMx && chmod +x install.sh && bash install.sh
                
                echo -e "\n${GREEN}✅ REINSTALACION LIMPIA COMPLETADA.${NC}"
                echo -e "${YELLOW}Presiona Enter...${NC}"
                read
                MX
                exit
            else
                menu_mantenimiento
            fi
            ;;
        0) main_menu ;;
        *) menu_mantenimiento ;;
    esac
}

# --- MENÚ AJUSTES DEL SCRIPT ---
menu_ajustes_script() {
    while true; do
        ui_header "CONFIGURACIÓN DEL SCRIPT"
        echo -e "  ${CYAN}[1]>${WHITE} ACTUALIZAR PANEL (GitHub Sync)${NC}"
        echo -e "  ${CYAN}[2]>${WHITE} REINSTALAR PANEL (Forzar Limpieza)${NC}"
        echo -e "  ${CYAN}[3]>${WHITE} CAMBIAR BANNER SSH (issue.net/Dropbear)${NC}"
        ui_subhr
        echo -e "  ${WHITE}[0] VOLVER AL MENÚ ANTERIOR${NC}"
        ui_hr
        ui_prompt " Selecciona una opción: "
        read opt_aj

        case $opt_aj in
            1) menu_mantenimiento ;;
            2) 
               echo -e "\n${RED}⚠️ REINSTALACION FORZADA SELECCIONADA${NC}"
               read -p "¿Deseas purgar TODO antes de reinstalar? [S/N]: " conf_p
               if [[ "$conf_p" == "S" || "$conf_p" == "s" ]]; then
                   purgar_sistema_total
                   # Re-clonar e instalar
                   cd /tmp || exit
                   rm -rf /tmp/MaximusVpsMx
                   git clone https://github.com/JuandeMx/MAXIMUS.git /tmp/MaximusVpsMx
                   cd /tmp/MaximusVpsMx && chmod +x install.sh && bash install.sh
               else
                   echo -e "\n${YELLOW}▶ Reinstalando componentes base sin purgar...${NC}"
                   bash /etc/MaximusVpsMx/install.sh
               fi
               sleep 2 ;;
            3)
               echo -e "\n${YELLOW}▶ Configuración del Banner SSH${NC}"
               echo -e "${CYAN}Escribe el nuevo mensaje para tus clientes:${NC}"
               read -p " > " new_banner
               echo -e "$new_banner" > /etc/issue.net
               echo -e "${GREEN}✅ Banner actualizado correctamente.${NC}"
               sleep 2 ;;
            4) 
               echo -e "\n${RED}================ ¡¡PELIGRO!! ================${NC}"
               read -p "¿Estás 100% seguro de destruir MaximusVpsMx? [S/N]: " desc
               if [[ "$desc" == "S" || "$desc" == "s" ]]; then
                   purgar_sistema_total
                   echo -e "${GREEN}✅ VUELO COMPLETADO. Servidor de fábrica.${NC}"
                   exit
               fi
               ;;
            0) main_menu ;;
        esac
    done
}

