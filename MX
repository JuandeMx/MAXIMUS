}

# --- SUBMENأڑ DE USUARIOS ---
menu_usuarios() {
    local USER_DB="/etc/MaximusVpsMx/users.db"
    mkdir -p /etc/MaximusVpsMx
    [ ! -f "$USER_DB" ] && touch "$USER_DB"

    # Hilo de Migraciأ³n Automأ،tica (v1 -> v2)
    if [ -f "$USER_DB" ]; then
        if [ $(head -n 1 "$USER_DB" | grep -o ":" | wc -l) -lt 4 ]; then
            echo -e "${YELLOW}âڑ™ï¸ڈ Migrando base de datos de usuarios al nuevo formato...${NC}"
            sed -i 's/$/:NONE:1/' "$USER_DB"
        fi
    fi

    ui_header "ADMINISTRACIأ“N DE CUENTAS SSH / DROPBEAR"
    echo -e "  ${CYAN}[1]>${WHITE} CREAR NUEVO USUARIO PREMIUM${NC}"
    echo -e "  ${CYAN}[2]>${RED} REMOVER / ELIMINAR USUARIO${NC}"
    echo -e "  ${CYAN}[3]>${WHITE} RENOVAR VENCIMIENTO${NC}"
    echo -e "  ${CYAN}[4]>${YELLOW} CAMBIAR CONTRASEأ‘A${NC}"
    echo -e "  ${CYAN}[5]>${WHITE} BLOQUEAR/DESBLOQUEAR USUARIO${NC}"
    ui_subhr
    echo -e "  ${CYAN}[7]>${GREEN} VER DETALLES DE TODOS LOS USUARIOS${NC}"
    echo -e "  ${CYAN}[8]>${WHITE} MONITOR DE CONEXIONES ACTUALES${NC}"
    echo -e "  ${CYAN}[10]>${WHITE} LIMPIAR USUARIOS VENCIDOS${NC}"
    ui_subhr
    echo -e "  ${CYAN}[12]>${WHITE} BACKUP DE BASE DE DATOS${NC}"
    echo -e "  ${CYAN}[15]>${YELLOW} ًں›،ï¸ڈ GESTIأ“N DE HUID / TOKEN${NC}"
    ui_hr
    echo -e "  ${WHITE}[0] VOLVER AL MENأڑ ANTERIOR${NC}"
    ui_hr
    ui_prompt " Selecciona una opciأ³n: "
    read opt_user

    case $opt_user in
        1)
            echo -e "\n${YELLOW}â–¶ Crear Usuario Premium${NC}"
            read -p " Nombre del Usuario: " user
            [ -z "$user" ] && menu_usuarios
            grep -qw "$user" "$USER_DB" && { echo -e "${RED}â‌Œ Error: Usuario ya existe.${NC}"; sleep 2; menu_usuarios; }
            read -p " Contraseأ±a: " pass
            read -p " Dأ­as de Duraciأ³n: " dias
            read -p " Lأ­mite de Conexiones [1]: " limit
            [ -z "$limit" ] && limit=1
            echo -e "${CYAN} آ؟Activar Bloqueo por HUID? (s/n)${NC}"
            read -p " Opciأ³n: " h_opt
            hwid_val="OFF"
            [[ "$h_opt" == "S" || "$h_opt" == "s" ]] && hwid_val="NONE"

            exp_date=$(date -d "+$dias days" +%Y-%m-%d)
            rm -f /etc/passwd.lock /etc/shadow.lock
            useradd -e $exp_date -s /bin/false -M $user 2>/dev/null
            echo "$user:$pass" | chpasswd
            echo "$user:$pass:$exp_date:$hwid_val:$limit" >> "$USER_DB"
            echo -e "${GREEN}âœ… Usuario $user creado ($limit SSH, HUID: $hwid_val) por $dias dأ­as.${NC}"
            ui_pause; menu_usuarios
            ;;
        2)
            echo -e "\n${RED}â–¶ Eliminar Sistema${NC}"
            read -p " Username a destruir: " user
            userdel -f $user 2>/dev/null
            sed -i "/^$user:/d" "$USER_DB" 2>/dev/null
            echo -e "${GREEN}âœ… Usuario eliminado de la base de datos.${NC}"
            ui_pause; menu_usuarios
            ;;
        3)
            echo -e "\n${YELLOW}â–¶ Renovar Usuario${NC}"
            read -p " Escribe el Username: " user
            grep -qw "$user" "$USER_DB" || { echo -e "${RED}â‌Œ Usuario no encontrado.${NC}"; sleep 2; menu_usuarios; }
            read -p " Dأ­as a Aأ±adir: " dias
            
            # Cأ،lculo de Renovaciأ³n Acumulativa
            old_exp=$(grep -w "^$user" "$USER_DB" | cut -d: -f3)
            current_sec=$(date +%s)
            old_sec=$(date -d "$old_exp" +%s 2>/dev/null)
            
            if [ "$old_sec" -gt "$current_sec" ]; then
                new_exp=$(date -d "$old_exp + $dias days" +%Y-%m-%d)
            else
                new_exp=$(date -d "+$dias days" +%Y-%m-%d)
            fi

            chage -E $new_exp $user 2>/dev/null
            sed -i "/^$user:/ s/:${old_exp}:/:${new_exp}:/" "$USER_DB"
            echo -e "${GREEN}âœ… Usuario renovado hasta el $new_exp.${NC}"
            ui_pause; menu_usuarios
            ;;
        4)
            echo -e "\n${YELLOW}â–¶ Editar Contraseأ±a${NC}"
            read -p " Escribe el Username: " user
            read -p " Nueva Contraseأ±a: " pass
            echo "$user:$pass" | chpasswd
            sed -i "/^$user:/ s/:[^:]*:/:${pass}:/2" "$USER_DB"
            echo -e "${GREEN}âœ… Contraseأ±a actualizada.${NC}"
            ui_pause; menu_usuarios
            ;;
        5)
            echo -e "\n${YELLOW}â–¶ Bloquear/Desbloquear Usuario${NC}"
            read -p " Username a modificar: " user
            estado=$(passwd -S $user 2>/dev/null | awk '{print $2}')
            if [[ "$estado" == "L" || "$estado" == "P" ]]; then
                usermod -U $user 2>/dev/null
                echo -e "${GREEN}âœ… Usuario $user DESBLOQUEADO (Active).${NC}"
            else
                usermod -L $user 2>/dev/null
                echo -e "${RED}ًں”’ Usuario $user BLOQUEADO (Lock).${NC}"
            fi
            sleep 2; menu_usuarios
            ;;
        7)
            echo -e "\n${YELLOW}â–¶ Detalles de Usuarios VIP (Elite Series):${NC}"
            ui_hr
            printf "${WHITE}%-12s | %-12s | %-10s | %-8s | %-6s${NC}\n" "USUARIO" "PASS" "EXPIRA" "HUID" "LIM"
            ui_subhr
            if [ -s "$USER_DB" ]; then
                while IFS=: read -r d_user d_pass d_exp d_hwid d_limit; do
                    h_color="${GREEN}" ; [ "$d_hwid" == "OFF" ] && h_color="${RED}"
                    printf " ${CYAN}%-11s${NC} | %-12s | %-10s | %b%-8s${NC} | %-6s\n" "$d_user" "$d_pass" "$d_exp" "$h_color" "$d_hwid" "$d_limit"
                done < "$USER_DB"
            else
                echo -e " ${RED}No hay usuarios registrados.${NC}"
            fi
            ui_hr
            ui_pause ; menu_usuarios
            ;;
        8)
            echo -e "\n${YELLOW}â–¶ MONITOR DE CONEXIONES ELITE${NC}"
            ui_hr
            printf "${WHITE}%-15s | %-15s | %-15s${NC}\n" "USUARIO" "IP ORIGEN" "DISPOSITIVO"
            ui_subhr
            # Monitor Simple: Cruzamos procesos de SSH/Dropbear con netstat
            netstat -antp 2>/dev/null | grep -E "sshd|dropbear" | grep ESTABLISHED | awk '{print $5, $7}' | while read -r rip rproc; do
                u_ip=$(echo $rip | cut -d: -f1)
                u_pid=$(echo $rproc | cut -d/ -f1)
                u_name=$(ps -u -p $u_pid 2>/dev/null | tail -n 1 | awk '{print $1}')
                [ -z "$u_name" ] && u_name="Unknown"
                printf " ${GREEN}%-14s${NC} | %-15s | ${CYAN}Verified${NC}\n" "$u_name" "$u_ip"
            done
            ui_hr
            ui_pause ; menu_usuarios
            ;;
        10)
            echo -e "\n${YELLOW}â–¶ Eliminando Usuarios Vencidos...${NC}"
            today=$(date +%s)
            ct=0
            while IFS=: read -r d_user d_pass d_exp d_hwid d_limit; do
                exp_sec=$(date -d "$d_exp" +%s 2>/dev/null)
                if [ ! -z "$exp_sec" ] && [ "$today" -gt "$exp_sec" ]; then
                    userdel -f "$d_user" 2>/dev/null
                    sed -i "/^$d_user:/d" "$USER_DB"
                    echo -e "${RED}ًں—‘ï¸ڈ Eliminado: $d_user (Venciأ³ el $d_exp)${NC}"
                    ct=$((ct+1))
                fi
            done < "$USER_DB"
            [ "$ct" -eq 0 ] && echo -e "${GREEN}Todo al dأ­a.${NC}" || echo -e "${GREEN}Limpieza terminada.${NC}"
            sleep 2; menu_usuarios
            ;;
        12)
            echo -e "\n${YELLOW}â–¶ Generando Backup Maximus...${NC}"
            tar -cvf /root/maximus_users_backup.tar "$USER_DB" /etc/passwd /etc/shadow 2>/dev/null
            echo -e "${GREEN}âœ… Backup guardado en /root/maximus_users_backup.tar${NC}"
            ui_pause; menu_usuarios
            ;;
        15) sub_huid ;; # Definir abajo
        0) break ;;
    esac
}

