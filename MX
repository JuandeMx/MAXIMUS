    echo -e "${RED}==========================${CYAN}Ram${RED}==========================${NC}"
    printf "${CYAN}Total:  ${WHITE}%-9s ${CYAN}En Uso: ${WHITE}%-9s ${CYAN}Libre: ${WHITE}%-9s${NC}\n" "$RAM_TOTAL" "$RAM_USO" "$RAM_FREE"
    printf "${CYAN}Buffer: ${WHITE}%-9s ${CYAN}Cache:  ${WHITE}%-9s${NC}\n" "$RAM_BUFF" "$RAM_CACHE"
    echo -e "${RED}=======================================================${NC}"
    printf "   ${CYAN}ACTIVOS: ${WHITE}%-4s ${RED}EXPIRADOS: ${WHITE}%-4s ${CYAN}TOTAL: ${WHITE}%-4s${NC}\n" "$ACTIVA" "$EXPIRADA" "$TOTAL"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${CYAN}[1]> ${WHITE}ADMINISTRAR CUENTAS (SSH/DROPBEAR)${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[2]> ${WHITE}CONFIGURACION DE PROTOCOLOS${NC}"
    echo -e "${CYAN}[3]> ${WHITE}HERRAMIENTAS EXTRAS${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[4]> ${WHITE}CONFIGURACION DEL SCRIPT${NC}"
    echo -e "${CYAN}[5]> ${WHITE}IDIOMA / LANGUAGE${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[6]> ${RED}[!] DESINSTALAR PANEL${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[9]> ${GREEN}ACTUALIZAR / REINSTALAR PANEL${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${WHITE}[0] SALIR DEL VPS     [7] SALIR SCRIPT    [8] REINICIAR${NC}"
    echo -e "${RED}=======================================================${NC}"
    
    # Imprimiendo el prompt sin salto de linea
    echo -ne "${YELLOW}Ingresa una Opcion: ${NC}"
    read main_opt

    case $main_opt in
        1) menu_usuarios ;;
        2) menu_protocolos ;;
        3) menu_sistema ;;
        4) menu_ajustes_script ;;
        5) echo -e "\n${YELLOW}▶ Idioma Actual: Español${NC}"; sleep 2; main_menu ;;
        6) 
            echo -e "\n${RED}================ ¡¡PELIGRO!! ================${NC}"
            read -p "¿Estás 100% seguro de destruir MaximusVpsMx? [S/N]: " desc
            if [[ "$desc" == "S" || "$desc" == "s" ]]; then
                echo -e "${RED}🔥 INICIANDO PURGA MASIVA...${NC}"
                systemctl stop stunnel4 dropbear mx-proxy badvpn mx-slowdns 2>/dev/null
                killall -9 stunnel4 dropbear python3 badvpn-udpgw 2>/dev/null
                rm -rf /etc/MaximusVpsMx
                rm -f /usr/local/bin/MX
                rm -f /etc/systemd/system/mx-proxy.service
                rm -f /etc/systemd/system/badvpn.service
                rm -f /etc/systemd/system/mx-slowdns.service
                apt-get purge stunnel4 dropbear -y 2>/dev/null
                systemctl daemon-reload
                echo -e "${GREEN}✅ VUELO COMPLETADO. El servidor vuelve a ser de fábrica.${NC}"
                exit
            else
                main_menu
            fi
            ;;
        7) clear; exit ;;
        8) echo -e "${YELLOW}🔄 Reiniciando VPS...${NC}"; reboot ;;
        9) menu_mantenimiento ;;
        0) clear; exit ;;
        *) main_menu ;;
    esac
}

