    echo -e "${RED}=======================================================${NC}"
    echo -e "${CYAN}[0]${RED} Volver             ${CYAN}[18]${WHITE} âģ Reiniciar Todos los MÃģdulos${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -ne "${YELLOW}Ingresa una Opcion: ${NC}"
    read opt_prot
    
    case $opt_prot in
        1) gestor_servicio "SSH" "ssh" ;;
