                    echo -e "\n${RED}Primero debes instalar X-UI.${NC}"; sleep 2
                else
                    echo -e "\n${YELLOW}▶ Cambiar Puerto del Panel X-UI${NC}"
                    read -p " Ingresa el nuevo puerto (ej. 54321): " n_port
