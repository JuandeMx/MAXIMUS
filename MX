            find /var/log -type f -name "*.[0-9]" -delete > /dev/null 2>&1
            find /var/log -type f -name "*.gz" -delete > /dev/null 2>&1
            find /var/log -type f -name "*.log.*" -delete > /dev/null 2>&1
            
            # Vaciar los logs activos
            find /var/log -type f -name "*.log" -exec truncate -s 0 {} + > /dev/null 2>&1
