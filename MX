# --- SUBMENÚ DE USUARIOS ---
menu_usuarios() {
    while true; do
        ui_header "ADMINISTRACIÓN DE CUENTAS SSH / DROPBEAR"
        echo -e "  ${CYAN}[1]>${WHITE} CREAR NUEVO USUARIO PREMIUM${NC}"
        echo -e "  ${CYAN}[2]>${RED} REMOVER / ELIMINAR USUARIO${NC}"
        echo -e "  ${CYAN}[3]>${WHITE} RENOVAR VENCIMIENTO${NC}"
        echo -e "  ${CYAN}[4]>${YELLOW} CAMBIAR CONTRASEÑA${NC}"
        echo -e "  ${CYAN}[5]>${WHITE} BLOQUEAR/DESBLOQUEAR USUARIO${NC}"
        ui_subhr
        echo -e "  ${CYAN}[7]>${GREEN} VER DETALLES DE TODOS LOS USUARIOS${NC}"
        echo -e "  ${CYAN}[8]>${WHITE} MONITOR DE CONEXIONES ACTUALES${NC}"
        echo -e "  ${CYAN}[10]>${WHITE} LIMPIAR USUARIOS VENCIDOS${NC}"
        ui_subhr
        echo -e "  ${CYAN}[12]>${WHITE} BACKUP DE BASE DE DATOS${NC}"
        echo -e "  ${CYAN}[15]>${YELLOW} 🛡️ GESTIÓN DE HUID / TOKEN${NC}"
        ui_hr
        echo -e "  ${WHITE}[0] VOLVER AL MENÚ ANTERIOR${NC}"
        ui_hr
        ui_prompt " Selecciona una opción: "
        read opt_user

        case $opt_user in
            1)
                echo -e "\n${YELLOW}▶ MODO DE CREACIÓN${NC}"
                echo -e "  ${CYAN}[1]${NC} Usuario Normal (Clásico)"
                echo -e "  ${CYAN}[2]${NC} Usuario Hardware ID (Invisible)"
                read -p " Opción: " tipo_creacion

                if [[ "$tipo_creacion" == "2" ]]; then
                    echo -e "\n${YELLOW}▶ Crear Cliente Hardware ID${NC}"
                    read -p " Nombre/Alias (Ej: Juan): " alias
                    [ -z "$alias" ] && continue
                    read -p " Hardware ID del Cliente: " hwid_val
                    [ -z "$hwid_val" ] && continue
                    # Transformamos el HWID a minúsculas para que Linux lo acepte
                    user=$(echo "$hwid_val" | tr '[:upper:]' '[:lower:]')
                    pass=$user
                    read -p " Días de Duración: " dias
                    [ -z "$dias" ] && dias=30
                    limit=1
                    
                    grep -qw "$user" "$USER_DB" && { echo -e "${RED}❌ Error: Este HWID ya está registrado.${NC}"; sleep 2; continue; }
                    
                    exp_date=$(date -d "+$dias days" +%Y-%m-%d)
                    linux_exp_date=$(date -d "+$((dias + 1)) days" +%Y-%m-%d)
                    
                    rm -f /etc/passwd.lock /etc/shadow.lock
                    useradd -e $linux_exp_date -s /bin/false -M $user 2>/dev/null
                    echo "$user:$pass" | chpasswd
                    echo "$user:$pass:$exp_date:HWID_INV:$limit:$alias" >> "$USER_DB"
                    echo "$user:$pass:$exp_date:100:100" >> /etc/MaximusVpsMx/hysteria_users.db
                    # Obtener IP y Dominio
                    server_ip=$(curl -s ifconfig.me)
                    domain=$(cat /etc/MaximusVpsMx/cloudflare.conf | grep "DOMAIN=" | cut -d= -f2)
                    [ -z "$domain" ] && domain="$server_ip"
                    
                    echo -e "\n${YELLOW}*====================================*${NC}"
                    echo -e "${WHITE}  CREACIÓN DE CLIENTE HWID EXITOSA${NC}"
                    echo -e "${YELLOW}*====================================*${NC}"
                    echo -e "${CYAN} DOMINIO :${NC} $domain"
                    echo -e "${CYAN} HOST/IP :${NC} $server_ip"
                    echo -e "${CYAN} ALIAS   :${NC} $alias"
                    echo -e "${CYAN} HWID    :${NC} $hwid_val"
                    echo -e "${CYAN} VALIDEZ :${NC} $exp_date ($dias Días)"
                    echo -e "${YELLOW}--------------------------------------${NC}"
                    echo -e "${WHITE} En APPS como HTTP Custom o Injector:${NC}"
                    echo -e "${GREEN} 👤 Usuario SSH :${NC} mxhwid"
                    echo -e "${GREEN} 🔑 Clave SSH   :${NC} mxhwid"
                    echo -e "${RED} (Recuerda exportar bloqueando el SSH)${NC}"
                    echo -e "${YELLOW}--------------------------------------${NC}"
                    ui_pause
                else
                    echo -e "\n${YELLOW}▶ Crear Usuario Premium${NC}"
                    read -p " Nombre del Usuario: " user
                    [ -z "$user" ] && continue
                    grep -qw "$user" "$USER_DB" && { echo -e "${RED}❌ Error: Usuario ya existe.${NC}"; sleep 2; continue; }
                    read -p " Contraseña: " pass
                    read -p " Días de Duración: " dias
                    [ -z "$dias" ] && dias=30
                    limit=1
                    
                    echo -e "${CYAN} ¿Activar Bloqueo por HUID? (s/n)${NC}"
                    read -p " Opción: " h_opt
                    hwid_val="OFF"
                    if [[ "$h_opt" == "S" || "$h_opt" == "s" ]]; then
                        echo -e "   ${YELLOW}▶ Selecciona el Método de Registro:${NC}"
                        echo -e "   [1] Automático (Capturar en primer login)"
                        echo -e "   [2] Manual (Ingresar Token ahora)"
                        read -p "   Opción [1]: " m_hwid
                        if [[ "$m_hwid" == "2" ]]; then
                            read -p "   Ingresa el Token/HUID: " hwid_val
                        else
                            hwid_val="NONE"
                        fi
                    fi

                    exp_date=$(date -d "+$dias days" +%Y-%m-%d)
                    linux_exp_date=$(date -d "+$((dias + 1)) days" +%Y-%m-%d)
                    rm -f /etc/passwd.lock /etc/shadow.lock
                    useradd -e $linux_exp_date -s /bin/false -M $user 2>/dev/null
                    echo "$user:$pass" | chpasswd
                    echo "$user:$pass:$exp_date:$hwid_val:$limit" >> "$USER_DB"
                    echo "$user:$pass:$exp_date:100:100" >> /etc/MaximusVpsMx/hysteria_users.db
                    echo -e "${GREEN}✅ Usuario $user creado (HUID: $hwid_val) por $dias días.${NC}"
                    ui_pause
                fi
                ;;
            2)
                echo -e "\n${RED}▶ Eliminar Usuario${NC}"
                read -p " Username a borrar: " user
                userdel -f $user 2>/dev/null
                sqlite3 "$DB_PATH" "DELETE FROM users WHERE username='$user'"
                echo -e "${GREEN}✅ Usuario eliminado.${NC}"
                ui_pause ;;
            3)
                echo -e "\n${YELLOW}▶ Renovar Usuario${NC}"
                read -p " Escribe el Username: " user
                grep -qw "$user" "$USER_DB" || { echo -e "${RED}❌ Usuario no encontrado.${NC}"; sleep 2; continue; }
                read -p " Días a Añadir: " dias
                
                # Cálculo de Renovación Acumulativa
                old_exp=$(grep -w "^$user" "$USER_DB" | cut -d: -f3)
                current_sec=$(date +%s)
                old_sec=$(date -d "$old_exp" +%s 2>/dev/null)
                
                if [ "$old_sec" -gt "$current_sec" ]; then
                    new_exp=$(date -d "$old_exp + $dias days" +%Y-%m-%d)
                else
                    new_exp=$(date -d "+$dias days" +%Y-%m-%d)
                fi

                chage -E $new_exp $user 2>/dev/null
                sed -i "/^$user:/ s/:${old_exp}:/:${new_exp}:/" "$USER_DB"
                echo -e "${GREEN}✅ Usuario renovado hasta el $new_exp.${NC}"
                ui_pause
                ;;
            4)
                echo -e "\n${YELLOW}▶ Editar Contraseña${NC}"
                read -p " Escribe el Username: " user
                read -p " Nueva Contraseña: " pass
                echo "$user:$pass" | chpasswd
                sed -i "/^$user:/ s/:[^:]*:/:${pass}:/2" "$USER_DB"
                echo -e "${GREEN}✅ Contraseña actualizada.${NC}"
                ui_pause
                ;;
            5)
                echo -e "\n${YELLOW}▶ Bloquear/Desbloquear Usuario${NC}"
                read -p " Username a modificar: " user
                estado=$(passwd -S $user 2>/dev/null | awk '{print $2}')
                if [[ "$estado" == "L" || "$estado" == "P" ]]; then
                    usermod -U $user 2>/dev/null
                    echo -e "${GREEN}✅ Usuario $user DESBLOQUEADO (Active).${NC}"
                else
                    usermod -L $user 2>/dev/null
                    echo -e "${RED}🔒 Usuario $user BLOQUEADO (Lock).${NC}"
                fi
                sleep 2
                ;;
            7)
                echo -e "\n${YELLOW}▶ LISTA DE USUARIOS${NC}"
                echo -e "  ${CYAN}[1]${NC} Ver Usuarios Normales"
                echo -e "  ${CYAN}[2]${NC} Ver Clientes HWID"
                read -p " Opción: " ver_opt
                ui_hr
                
                if [[ "$ver_opt" == "2" ]]; then
                    printf "${WHITE}%-15s | %-12s | %-10s${NC}\n" "ALIAS" "HWID CODE" "EXPIRA"
                    ui_subhr
                    if [ -s "$USER_DB" ]; then
                        encontrados=0
                        while IFS=: read -r d_user d_pass d_exp d_hwid d_limit d_alias; do
                            if [[ "$d_hwid" == "HWID_INV" ]]; then
                                printf " ${CYAN}%-14s${NC} | %-12s | %-10s\n" "$d_alias" "$d_user" "$d_exp"
                                encontrados=1
                            fi
                        done < "$USER_DB"
                        [ "$encontrados" -eq 0 ] && echo -e " ${RED}No hay clientes HWID registrados.${NC}"
                    else
                        echo -e " ${RED}No hay usuarios registrados.${NC}"
                    fi
                else
                    printf "${WHITE}%-12s | %-12s | %-10s | %-8s | %-6s${NC}\n" "USUARIO" "PASS" "EXPIRA" "HUID" "LIM"
                    ui_subhr
                    if [ -s "$USER_DB" ]; then
                        encontrados=0
                        while IFS=: read -r d_user d_pass d_exp d_hwid d_limit d_alias; do
                            if [[ "$d_hwid" != "HWID_INV" ]]; then
                                h_color="${GREEN}" ; [ "$d_hwid" == "OFF" ] && h_color="${RED}"
                                printf " ${CYAN}%-11s${NC} | %-12s | %-10s | %b%-8s${NC} | %-6s\n" "$d_user" "$d_pass" "$d_exp" "$h_color" "$d_hwid" "$d_limit"
                                encontrados=1
                            fi
                        done < "$USER_DB"
                        [ "$encontrados" -eq 0 ] && echo -e " ${RED}No hay usuarios normales registrados.${NC}"
                    else
                        echo -e " ${RED}No hay usuarios registrados.${NC}"
                    fi
                fi
                ui_hr
                ui_pause
                ;;
            8)
                echo -e "\n${YELLOW}▶ MONITOR DE CONEXIONES ELITE${NC}"
                ui_hr
                printf "${WHITE}%-15s | %-15s | %-15s${NC}\n" "USUARIO" "IP ORIGEN" "DISPOSITIVO"
                ui_subhr
                # Monitor Simple: Cruzamos procesos de SSH/Dropbear con netstat
                netstat -antp 2>/dev/null | grep -E "sshd|dropbear" | grep ESTABLISHED | awk '{print $5, $7}' | while read -r rip rproc; do
                    u_ip=$(echo $rip | cut -d: -f1)
                    u_pid=$(echo $rproc | cut -d/ -f1)
                    u_name=$(ps -u -p $u_pid 2>/dev/null | tail -n 1 | awk '{print $1}')
                    [ -z "$u_name" ] && u_name="Unknown"
                    printf " ${GREEN}%-14s${NC} | %-15s | ${CYAN}Verified${NC}\n" "$u_name" "$u_ip"
                done
                ui_hr
                ui_pause
                ;;
            10)
                echo -e "\n${YELLOW}▶ Eliminando Usuarios Vencidos...${NC}"
                today=$(date +%s)
                ct=0
                while IFS=: read -r d_user d_pass d_exp d_hwid d_limit; do
                    exp_sec=$(date -d "$d_exp" +%s 2>/dev/null)
                    if [ ! -z "$exp_sec" ] && [ "$today" -gt "$exp_sec" ]; then
                        userdel -f "$d_user" 2>/dev/null
                        sed -i "/^$d_user:/d" "$USER_DB"
                        echo -e "${RED}🗑️ Eliminado: $d_user (Venció el $d_exp)${NC}"
                        ct=$((ct+1))
                    fi
                done < "$USER_DB"
            ;;
        12)
            echo -e "\n${YELLOW}▶ Generando Backup Maximus...${NC}"
            tar -cvf /root/maximus_users_backup.tar "$USER_DB" /etc/passwd /etc/shadow 2>/dev/null
            echo -e "${GREEN}✅ Backup guardado en /root/maximus_users_backup.tar${NC}"
            ui_pause ;;
        15) sub_huid ;; # Definir abajo
        0) return ;;
    esac
done
}

# --- SUBMENÚ HUID ---
sub_huid() {
    local USER_DB="/etc/MaximusVpsMx/users.db"
    while true; do
        ui_header "GESTIÓN DE SEGURIDAD HUID / TOKEN"
        echo -e "  ${CYAN}[1]>${WHITE} LISTAR USUARIOS CON HUID ACTIVO${NC}"
        echo -e "  ${CYAN}[2]>${YELLOW} RESETEAR / LIMPIAR HUID DE UN USUARIO${NC}"
        echo -e "  ${CYAN}[3]>${WHITE} ASIGNAR HUID MANUALMENTE${NC}"
        echo -e "  ${CYAN}[4]>${RED} DESACTIVAR HUID A UN USUARIO${NC}"
        ui_hr
        echo -e "  ${WHITE}[0] VOLVER${NC}"
        ui_hr
        ui_prompt " Selecciona: " ; read opt_h
        
        case $opt_h in
            1)
                ui_header "USUARIOS CON BLOQUEO DISPOSITIVO"
                printf "${WHITE}%-15s | %-30s${NC}\n" "USUARIO" "HARDWARE ID (TOKEN)"
                ui_subhr
                grep -v ":OFF:" "$USER_DB" | while IFS=: read -r d_user d_pass d_exp d_hwid d_limit; do
                    printf " ${GREEN}%-14s${NC} | ${CYAN}%-30s${NC}\n" "$d_user" "$d_hwid"
                done
                ui_pause ;;
            2)
                read -p " Username para Resetear HUID: " user
                sed -i "/^$user:/ s/\(:[^:]*:[^:]*:\)[^:]*:/\1NONE:/" "$USER_DB"
                echo -e "${GREEN}✅ HUID reseteado. El próximo ingreso capturará el nuevo ID.${NC}"; ui_pause ;;
            3)
                read -p " Username: " user; read -p " Nuevo HUID (Token): " n_huid
                sed -i "/^$user:/ s/\(:[^:]*:[^:]*:\)[^:]*:/\1$n_huid:/" "$USER_DB"
                echo -e "${GREEN}✅ HUID asignado manualmente.${NC}"; ui_pause ;;
            4)
                read -p " Username para Desactivar HUID: " user
                sed -i "/^$user:/ s/\(:[^:]*:[^:]*:\)[^:]*:/\1OFF:/" "$USER_DB"
                echo -e "${RED}🔒 Bloqueo HUID desactivado.${NC}"; ui_pause ;;
            0) return ;;
        esac
    done
}

