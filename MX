#!/bin/bash
# MaximusVpsMx - Super Panel v2.0
# Modificado para Submenús y Funciones Avanzadas

# SEGURIDAD: Solo root puede ejecutar este panel
if [ "$EUID" -ne 0 ]; then
    echo -e "\033[1;31m❌ Acceso Denegado. Solo root puede usar MaximusVpsMx.\033[0m"
    exit 1
fi

# Colores Analíticos e Interfaz
RED='\033[1;31m'
GREEN='\033[1;32m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
WHITE='\033[1;37m'
NC='\033[0m'

# Telemetría Global
get_telemetry() {
    IP=$(wget -qO- ipv4.icanhazip.com 2>/dev/null)
    [ -z "$IP" ] && IP="127.0.0.1"
    OS=$(grep -w PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')
    [ -z "$OS" ] && OS="Ubuntu 20.04"
    
    FECHA=$(date +"%d-%m-%Y")
    HORA=$(date +"%H:%M:%S")

    # Disco
    DISC_TOTAL=$(df -h / | awk 'NR==2 {print $2}')
    DISC_USO=$(df -h / | awk 'NR==2 {print $3}')
    DISC_FREE=$(df -h / | awk 'NR==2 {print $4}')
    DISC_DISP=$(df -h / | awk 'NR==2 {print $4}')

    # CPU
    CORES=$(nproc)
    CPU_USE=$(top -bn1 | grep load | awk '{printf "%.2f%%", $(NF-2) * 10}')
    [ -z "$CPU_USE" ] && CPU_USE="0.00%"

    # RAM
    RAM_TOTAL=$(free -m | awk 'NR==2 {printf "%.2fGB", $2/1024}')
    RAM_USO=$(free -m | awk 'NR==2 {printf "%.2fGB", $3/1024}')
    RAM_FREE=$(free -m | awk 'NR==2 {printf "%.2fMB", $4}')
    RAM_BUFF=$(awk '/Buffers:/ {printf("%.2fMB", $2/1024)}' /proc/meminfo)
    RAM_CACHE=$(awk '/^Cached:/ {printf("%.2fMB", $2/1024)}' /proc/meminfo)

    # Cuentas SSH
    if [ -f /etc/MaximusVpsMx/users.db ]; then
        TOTAL=$(wc -l < /etc/MaximusVpsMx/users.db)
        ACTIVA=$(grep -v "^#" /etc/MaximusVpsMx/users.db | wc -l)
        EXPIRADA=0
        BLOQUEADA=0
    else
        TOTAL=0; ACTIVA=0; EXPIRADA=0; BLOQUEADA=0
    fi
}

# --- SUBMENÚ DE USUARIOS ---
menu_usuarios() {
    clear
    echo -e " ${GREEN}< BY JUANDEMX >${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${YELLOW}           ADMINISTRACION DE USUARIOS SSH${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${CYAN}[1]>${WHITE} NUEVO USUARIO${NC}"
    echo -e "${CYAN}[2]>${RED} REMOVER USUARIO${NC}"
    echo -e "${CYAN}[3]>${WHITE} RENOVAR USUARIO${NC}"
    echo -e "${CYAN}[4]>${YELLOW} EDITAR USUARIO${NC}"
    echo -e "${CYAN}[5]>${WHITE} BLOQUEAR/DESBLOQUEAR USUARIO${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[6]>${WHITE} CONFIGURAR CONTRASEÑA GENERAL${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[7]>${GREEN} DETALLES DE TODOS USUARIOS${NC}"
    echo -e "${CYAN}[8]>${WHITE} MONITOR DE USUARIOS CONECTADOS${NC}"
    echo -e "${CYAN}[9]>${YELLOW} LIMITADOR-DE-CUENTAS${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[10]>${WHITE} ELIMINAR USUARIOS VENCIDOS${NC}"
    echo -e "${CYAN}[11]>${RED} ELIMINAR TODOS LOS USUARIOS${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[12]>${WHITE} ADMINISTRACION COPIAS DE USUARIOS${NC}"
    echo -e "${CYAN}[13]>${BLUE} DESACTIVAR CONTRASEÑA ALFANUMERICA${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[14]>${WHITE} CONFIGURACION ADMINISTRADOR DE CUENTAS${NC}"
    echo -e "${RED}=======================================================${NC}"
    # Se ajusta longitud a 55 caracteres. " Volver" (7) + ESPACIOS(12) + " [15]" (4) + "CAMBIAR..." (32) = 55
    echo -e "${CYAN}[0]${RED} Volver            ${CYAN}[15]${WHITE} CAMBIAR A MODO SSH/HWID/TOKE${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -ne "${YELLOW}Ingresa una Opcion: ${NC}"
    read opt_user

    case $opt_user in
        1)
            echo -e "\n${YELLOW}▶ Crear Usuario Premium${NC}"
            read -p " Nombre (1-20 chars): " user
            read -p " Contraseña: " pass
            read -p " Días de Duración: " dias
            exp_date=$(date -d "+$dias days" +%Y-%m-%d)
            rm -f /etc/passwd.lock /etc/shadow.lock /etc/group.lock /etc/gshadow.lock
            useradd -e $exp_date -s /bin/false -M $user 2>/dev/null
            echo "$user:$pass" | chpasswd
            echo "$user:$pass:$exp_date" >> /etc/MaximusVpsMx/users.db
            echo -e "${GREEN}✅ Usuario $user creado por $dias días.${NC}"
            sleep 2; menu_usuarios
            ;;
        2)
            echo -e "\n${RED}▶ Eliminar Sistema${NC}"
            read -p " Username a destruir: " user
            rm -f /etc/passwd.lock /etc/shadow.lock /etc/group.lock /etc/gshadow.lock
            userdel -f $user 2>/dev/null
            sed -i "/^$user:/d" /etc/MaximusVpsMx/users.db 2>/dev/null
            echo -e "${GREEN}✅ Exterminado.${NC}"
            sleep 2; menu_usuarios
            ;;
        3)
            echo -e "\n${YELLOW}▶ Renovar Usuario${NC}"
            read -p " Escribe el Username: " user
            read -p " Días a Añadir: " dias
            exp_date=$(date -d "+$dias days" +%Y-%m-%d)
            chage -E $exp_date $user 2>/dev/null
            old_pass=$(grep -w "^$user" /etc/MaximusVpsMx/users.db | cut -d: -f2)
            sed -i "/^$user:/d" /etc/MaximusVpsMx/users.db
            echo "$user:$old_pass:$exp_date" >> /etc/MaximusVpsMx/users.db
            echo -e "${GREEN}✅ Usuario renovado.${NC}"
            sleep 2; menu_usuarios
            ;;
        4)
            echo -e "\n${YELLOW}▶ Editar Contraseña${NC}"
            read -p " Escribe el Username: " user
            read -p " Nueva Contraseña: " pass
            echo "$user:$pass" | chpasswd
            exp_date=$(grep -w "^$user" /etc/MaximusVpsMx/users.db | cut -d: -f3)
            sed -i "/^$user:/d" /etc/MaximusVpsMx/users.db
            echo "$user:$pass:$exp_date" >> /etc/MaximusVpsMx/users.db
            echo -e "${GREEN}✅ Contraseña actualizada.${NC}"
            sleep 2; menu_usuarios
            ;;
        5)
            echo -e "\n${YELLOW}▶ Bloquear/Desbloquear Usuario${NC}"
            read -p " Username a modificar: " user
            estado=$(passwd -S $user 2>/dev/null | awk '{print $2}')
            if [ "$estado" == "L" ]; then
                usermod -U $user 2>/dev/null
                echo -e "${GREEN}✅ Usuario $user DESBLOQUEADO.${NC}"
            else
                usermod -L $user 2>/dev/null
                echo -e "${RED}🔒 Usuario $user BLOQUEADO.${NC}"
            fi
            sleep 2; menu_usuarios
            ;;
        6)
            echo -e "\n${YELLOW}▶ Configurar Contraseña General (Próximamente)${NC}"
            sleep 2; menu_usuarios
            ;;
        7)
            echo -e "\n${YELLOW}▶ Detalles de Todos los Usuarios VIP:${NC}"
            echo -e "${CYAN}================================================================${NC}"
            printf "${WHITE}%-15s | %-15s | %-20s${NC}\n" "USUARIO" "CONTRASEÑA" "VENCIMIENTO"
            echo -e "${CYAN}================================================================${NC}"
            if [ -f /etc/MaximusVpsMx/users.db ]; then
                while IFS=: read -r d_user d_pass d_exp; do
                    printf " ${GREEN}%-14s${NC} | ${YELLOW}%-15s${NC} | ${RED}%-20s${NC}\n" "$d_user" "$d_pass" "$d_exp"
                done < /etc/MaximusVpsMx/users.db
            else
                echo -e " ${RED}No hay usuarios registrados aún en la base de datos.${NC}"
            fi
            echo -e "${CYAN}================================================================${NC}"
            read -p "Presiona Enter para volver..." ; menu_usuarios
            ;;
        8)
            echo -e "\n${YELLOW}▶ Monitor de Usuarios Conectados AHORA Mismo:${NC}"
            netstat -tnpa 2>/dev/null | grep ESTABLISHED | grep -E 'sshd|dropbear' | awk '{print $5}' | cut -d: -f1 | sort | uniq -c
            read -p "Presiona Enter..." ; menu_usuarios
            ;;
        9)
            echo -e "\n${YELLOW}▶ Limitador de Cuentas (Próximamente)${NC}"
            sleep 2; menu_usuarios
            ;;
        10)
            echo -e "\n${YELLOW}▶ Eliminando Usuarios Vencidos...${NC}"
            today=$(date +%s)
            ct=0
            if [ -f /etc/MaximusVpsMx/users.db ]; then
                while IFS=: read -r d_user d_pass d_exp; do
                    exp_sec=$(date -d "$d_exp" +%s 2>/dev/null)
                    if [ ! -z "$exp_sec" ] && [ "$today" -gt "$exp_sec" ]; then
                        userdel -f "$d_user" 2>/dev/null
                        sed -i "/^$d_user:/d" /etc/MaximusVpsMx/users.db
                        echo -e "${RED}🗑️ Eliminado: $d_user (Venció el $d_exp)${NC}"
                        ct=$((ct+1))
                    fi
                done < /etc/MaximusVpsMx/users.db
                if [ "$ct" -eq 0 ]; then echo -e "${GREEN}No se encontraron usuarios vencidos.${NC}"; fi
            fi
            sleep 2; menu_usuarios
            ;;
        11)
            echo -e "\n${RED}⚠️ ¡PELIGRO! ¿Eliminar TODOS los usuarios? (S/N): ${NC}"
            read -p " Confirmar: " conf
            if [[ "$conf" == "S" || "$conf" == "s" ]]; then
                if [ -f /etc/MaximusVpsMx/users.db ]; then
                    while IFS=: read -r d_user d_pass d_exp; do
                        userdel -f "$d_user" 2>/dev/null
                    done < /etc/MaximusVpsMx/users.db
                    > /etc/MaximusVpsMx/users.db
                    echo -e "${RED}🔥 Todos los usuarios han sido purgados.${NC}"
                fi
            fi
            sleep 2; menu_usuarios
            ;;
        12)
            echo -e "\n${YELLOW}▶ Generando Backup Manual de Cuentas...${NC}"
            tar -cvf /root/users_backup.tar /etc/passwd /etc/shadow /etc/MaximusVpsMx/users.db 2>/dev/null
            echo -e "${GREEN}✅ Guardado en /root/users_backup.tar${NC}"
            sleep 2; menu_usuarios
            ;;
        13)
            echo -e "\n${YELLOW}▶ Desactivar Contraseña Alfanumérica (Próximamente)${NC}"
            sleep 2; menu_usuarios
            ;;
        14)
            echo -e "\n${YELLOW}▶ Configuración del Administrador (Próximamente)${NC}"
            sleep 2; menu_usuarios
            ;;
        15)
            echo -e "\n${YELLOW}▶ Modo SSH/HWID/TOKEN (Próximamente)${NC}"
            sleep 2; menu_usuarios
            ;;
        0) main_menu ;;
        *) menu_usuarios ;;
    esac
}

# --- SUBMENÚ DE PROTOCOLOS ---
menu_protocolos() {
    clear
    systemctl is-active --quiet mx-proxy && st_proxy="${GREEN}ONLINE${NC}" || st_proxy="${RED}OFFLINE${NC}"
    systemctl is-active --quiet dropbear && st_drop="${GREEN}ONLINE${NC}" || st_drop="${RED}OFFLINE${NC}"
    systemctl is-active --quiet stunnel4 && st_stun="${GREEN}ONLINE${NC}" || st_stun="${RED}OFFLINE${NC}"
    systemctl is-active --quiet badvpn && st_udp="${GREEN}ONLINE${NC}" || st_udp="${RED}OFFLINE${NC}"
    systemctl is-active --quiet mx-slowdns && st_dns="${GREEN}ONLINE${NC}" || st_dns="${RED}OFFLINE${NC}"

    echo -e " ${GREEN}< BY JUANDEMX >${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${YELLOW}           🔌 CONFIGURACION DE PROTOCOLOS 🔌${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${CYAN}[1]> ${WHITE}Python Proxy (Puerto 80)     : $st_proxy"
    echo -e "${CYAN}[2]> ${WHITE}Dropbear SSH (Puerto 44)     : $st_drop"
    echo -e "${CYAN}[3]> ${WHITE}Stunnel SSL  (Puerto 443)    : $st_stun"
    echo -e "${CYAN}[4]> ${WHITE}BadVPN UDP   (Puerto 7300)   : $st_udp"
    echo -e "${CYAN}[5]> ${WHITE}SlowDNS 🌐   (Puerto 53)     : $st_dns"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[6]> ${WHITE}⟳ Reiniciar TODOS los Servicios${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${WHITE}[0] VOLVER AL MENÚ PRINCIPAL${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -ne "${YELLOW}Ingresa una Opcion: ${NC}"
    read opt_prot
    
    case $opt_prot in
        1)
            read -p "¿Acción para Python Proxy? [1=Start, 2=Stop, 3=Enable (Arranque), 4=Disable]: " act
            if [ "$act" == "1" ]; then systemctl start mx-proxy; fi
            if [ "$act" == "2" ]; then systemctl stop mx-proxy; fi
            if [ "$act" == "3" ]; then systemctl enable mx-proxy; systemctl start mx-proxy; fi
            if [ "$act" == "4" ]; then systemctl disable mx-proxy; systemctl stop mx-proxy; fi
            menu_protocolos ;;
        2)
            read -p "¿Acción para Dropbear SSH? [1=Start, 2=Stop, 3=Enable (Arranque), 4=Disable]: " act
            if [ "$act" == "1" ]; then systemctl start dropbear; fi
            if [ "$act" == "2" ]; then systemctl stop dropbear; fi
            if [ "$act" == "3" ]; then systemctl enable dropbear; systemctl start dropbear; fi
            if [ "$act" == "4" ]; then systemctl disable dropbear; systemctl stop dropbear; fi
            menu_protocolos ;;
        3)
            read -p "¿Acción para Stunnel SSL? [1=Start, 2=Stop, 3=Enable (Arranque), 4=Disable]: " act
            if [ "$act" == "1" ]; then systemctl start stunnel4; fi
            if [ "$act" == "2" ]; then systemctl stop stunnel4; fi
            if [ "$act" == "3" ]; then systemctl enable stunnel4; systemctl start stunnel4; fi
            if [ "$act" == "4" ]; then systemctl disable stunnel4; systemctl stop stunnel4; fi
            menu_protocolos ;;
        4)
            read -p "¿Acción para BadVPN UDP?  [1=Start, 2=Stop, 3=Enable (Arranque), 4=Disable]: " act
            if [ "$act" == "1" ]; then systemctl start badvpn; fi
            if [ "$act" == "2" ]; then systemctl stop badvpn; fi
            if [ "$act" == "3" ]; then systemctl enable badvpn; systemctl start badvpn; fi
            if [ "$act" == "4" ]; then systemctl disable badvpn; systemctl stop badvpn; fi
            menu_protocolos ;;
        5)
            clear
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            echo -e "${WHITE}        🌐 SLOWDNS MANAGER 🌐${NC}"
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            
            systemctl is-active --quiet mx-slowdns && dns_estado="${GREEN}ACTIVO${NC}" || dns_estado="${RED}INACTIVO${NC}"
            NS_DOMAIN=$(cat /etc/MaximusVpsMx/slowdns/ns-domain.conf 2>/dev/null || echo "no configurado")
            
            echo -e " Estado: $dns_estado"
            echo -e " Dominio NS: ${YELLOW}$NS_DOMAIN${NC}"
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            echo -e "${GREEN} [1] Activar SlowDNS${NC}"
            echo -e "${RED} [2] Desactivar SlowDNS${NC}"
            echo -e "${YELLOW} [3] 🔑 Ver Llave Pública (Para el Cliente)${NC}"
            echo -e "${YELLOW} [4] Cambiar Dominio NS${NC}"
            echo -e "${CYAN} [5] 🔄 Regenerar Llaves RSA${NC}"
            echo -e "${RED} [0] Volver${NC}"
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            read -p "Opción SlowDNS: " opt_dns
            
            case $opt_dns in
                1)
                    systemctl enable --now mx-slowdns
                    echo -e "${GREEN}✅ SlowDNS Activado en puerto 53.${NC}"
                    sleep 2; menu_protocolos ;;
                2)
                    systemctl stop mx-slowdns
                    systemctl disable mx-slowdns
                    echo -e "${RED}⚠️ SlowDNS Desactivado.${NC}"
                    sleep 2; menu_protocolos ;;
                3)
                    echo -e "\n${CYAN}════════════════════════════════════════${NC}"
                    echo -e "${WHITE}  🔑 LLAVE PÚBLICA SLOWDNS${NC}"
                    echo -e "${CYAN}════════════════════════════════════════${NC}"
                    if [ -f /etc/MaximusVpsMx/slowdns/server.pub ]; then
                        echo -e "${YELLOW}"
                        cat /etc/MaximusVpsMx/slowdns/server.pub
                        echo -e "${NC}"
                        echo -e "${GREEN}📋 Copia esta llave completa en HTTP Custom → SlowDns → Key${NC}"
                        echo -e "${GREEN}🌐 DNS Server: $NS_DOMAIN${NC}"
                    else
                        echo -e "${RED}❌ No se encontraron llaves. Ejecuta: openssl genrsa -out /etc/MaximusVpsMx/slowdns/server.key 2048${NC}"
                    fi
                    echo -e "${CYAN}════════════════════════════════════════${NC}"
                    read -p "Presiona Enter..." ; menu_protocolos ;;
                4)
                    read -p "Nuevo dominio NS (ej: slow.tudominio.com): " new_ns
                    echo "$new_ns" > /etc/MaximusVpsMx/slowdns/ns-domain.conf
                    # Actualizar servicio con nuevo dominio
                    sed -i "s|slow\.vpsmx\.store|$new_ns|g" /etc/systemd/system/mx-slowdns.service
                    systemctl daemon-reload
                    systemctl restart mx-slowdns 2>/dev/null
                    echo -e "${GREEN}✅ Dominio NS actualizado a: $new_ns${NC}"
                    sleep 2; menu_protocolos ;;
                5)
                    echo -e "${YELLOW}⚠️ Esto invalidará las llaves actuales de los clientes.${NC}"
                    read -p "¿Continuar? (s/n): " confirmar
                    if [ "$confirmar" == "s" ]; then
                        openssl genrsa -out /etc/MaximusVpsMx/slowdns/server.key 2048 2>/dev/null
                        openssl rsa -in /etc/MaximusVpsMx/slowdns/server.key -pubout -out /etc/MaximusVpsMx/slowdns/server.pub 2>/dev/null
                        systemctl restart mx-slowdns 2>/dev/null
                        echo -e "${GREEN}✅ Llaves regeneradas. Los clientes necesitan la nueva llave pública.${NC}"
                    fi
                    sleep 2; menu_protocolos ;;
                *) menu_protocolos ;;
            esac
            ;;
        6)
            echo "🔄 Reiniciando toda la red..."
            systemctl restart mx-proxy dropbear stunnel4 badvpn mx-slowdns
            sleep 2; menu_protocolos ;;
        0) main_menu ;;
        *) menu_protocolos ;;
    esac
}

# --- SUBMENÚ DE SISTEMA ---
menu_sistema() {
    clear
    ufw status | grep -q "active" && fw_st="${GREEN}[Activo]${NC}" || fw_st="${RED}[Inactivo]${NC}"
    
    # Detectar estado de Cloudflare DDNS
    crontab -l 2>/dev/null | grep -q "cloudflare-ddns" && cf_st="${GREEN}[Activo cada 5min]${NC}" || cf_st="${RED}[Inactivo]${NC}"
    
    echo -e " ${GREEN}< BY JUANDEMX >${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${YELLOW}               ⚙️ HERRAMIENTAS EXTRAS ⚙️${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${CYAN}[1]> ${WHITE}Optimizar VPS (Limpiar RAM y Caché)${NC}"
    echo -e "${CYAN}[2]> ${WHITE}Editor de Banner Personal (Mensaje Global)${NC}"
    echo -e "${CYAN}[3]> ${WHITE}Respaldar Usuarios Localmente (Backup)${NC}"
    echo -e "${CYAN}[4]> ${WHITE}Gestor de Red y Transferencias (vnstat)${NC}"
    echo -e "${RED}-------------------------------------------------------${NC}"
    echo -e "${CYAN}[5]> ${WHITE}Activar/Desactivar Firewall UFW   | $fw_st${NC}"
    echo -e "${CYAN}[6]> ${WHITE}☁️ Cloudflare DDNS (IP Dinámica)  | $cf_st${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e "${WHITE}[0] VOLVER AL MENÚ PRINCIPAL${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -ne "${YELLOW}Ingresa una Opcion: ${NC}"
    read opt_sys
    
    case $opt_sys in
        1)
            echo -e "\n${YELLOW}▶ Limpiando Memoria RAM Inactiva...${NC}"
            sync; echo 3 > /proc/sys/vm/drop_caches
            swapoff -a && swapon -a
            echo -e "${GREEN}✅ El VPS se siente fresco y rápido.${NC}"
            sleep 2; menu_sistema ;;
        2)
            echo -e "\n${YELLOW}▶ Ingrese nuevo texto HTML para el Banner (Ctrl+O para guardar, Ctrl+X para salir)${NC}"
            sleep 3
            nano /etc/issue.net
            menu_sistema ;;
        3)
            echo -e "\n${YELLOW}▶ Generando Backup...${NC}"
            tar -cvf /root/users_backup.tar /etc/passwd /etc/shadow 2>/dev/null
            echo -e "${GREEN}✅ Guardado en /root/users_backup.tar${NC}"
            sleep 2; menu_sistema ;;
        4)
            echo -e "\n${YELLOW}▶ Tráfico de Red (Mes actual)${NC}"
            vnstat -m
            read -p "Presiona Enter para continuar..." ; menu_sistema ;;
        5)
            echo -e "\n${YELLOW}▶ Administrador de Firewall UFW${NC}"
            read -p "¿Qué deseas hacer? [1=Activar Seguro, 2=Desactivar]: " actf
            if [ "$actf" == "1" ]; then
                echo "Permitiendo puertos críticos..."
                ufw allow 22/tcp 2>/dev/null; ufw allow 44/tcp 2>/dev/null; ufw allow 80/tcp 2>/dev/null; ufw allow 443/tcp 2>/dev/null; ufw allow 7300/udp 2>/dev/null
                ufw --force enable
                echo -e "${GREEN}✅ Firewall Activado y Blindado.${NC}"
            elif [ "$actf" == "2" ]; then
                ufw disable
                echo -e "${RED}⚠️ Firewall Apagado.${NC}"
            fi
            sleep 2; menu_sistema ;;
        6)
            echo -e "\n${CYAN}════════════════════════════════════════${NC}"
            echo -e "${WHITE}     ☁️  CLOUDFLARE DDNS MANAGER ☁️${NC}"
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            echo -e "${GREEN} [1] Configurar Credenciales de Cloudflare${NC}"
            echo -e "${GREEN} [2] Activar DDNS (Cada 5 minutos)${NC}"
            echo -e "${RED} [3] Desactivar DDNS${NC}"
            echo -e "${YELLOW} [4] Forzar Comprobación AHORA${NC}"
            echo -e "${YELLOW} [5] Ver Log de Cambios de IP${NC}"
            echo -e "${YELLOW} [6] Ver Configuración Actual${NC}"
            echo -e "${RED} [0] Volver${NC}"
            echo -e "${CYAN}════════════════════════════════════════${NC}"
            read -p "Opción DDNS: " opt_cf

            case $opt_cf in
                1)
                    echo -e "\n${YELLOW}▶ Configurar Cloudflare DDNS${NC}"
                    echo -e "${WHITE}Necesitas los siguientes datos de tu cuenta Cloudflare:${NC}"
                    echo -e "${CYAN}(Encuéntralos en: dash.cloudflare.com → API Tokens)${NC}\n"
                    read -p " 🔑 API Token: " cf_token
                    read -p " 🌐 Zone ID: " cf_zone
                    read -p " 📛 Dominio (ej: vpsmx.tudominio.com): " cf_domain
                    
                    cat > /etc/MaximusVpsMx/cloudflare.conf << CFEOF
# Cloudflare DDNS Config - MaximusVpsMx
CF_API_TOKEN="$cf_token"
CF_ZONE_ID="$cf_zone"
CF_RECORD_NAME="$cf_domain"
CFEOF
                    chmod 600 /etc/MaximusVpsMx/cloudflare.conf
                    echo -e "\n${GREEN}✅ Credenciales guardadas de forma segura.${NC}"
                    sleep 2; menu_sistema ;;
                2)
                    if [ ! -f /etc/MaximusVpsMx/cloudflare.conf ]; then
                        echo -e "${RED}❌ Primero configura las credenciales (Opción 1).${NC}"
                        sleep 2; menu_sistema
                        return
                    fi
                    chmod +x /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                    # Agregar al cron cada 5 minutos
                    (crontab -l 2>/dev/null | grep -v "cloudflare-ddns"; echo "*/5 * * * * /etc/MaximusVpsMx/modules/cloudflare-ddns.sh") | crontab -
                    # Ejecutar una vez inmediatamente
                    /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                    echo -e "${GREEN}✅ DDNS Activado. Comprobará tu IP cada 5 minutos.${NC}"
                    sleep 2; menu_sistema ;;
                3)
                    crontab -l 2>/dev/null | grep -v "cloudflare-ddns" | crontab -
                    echo -e "${RED}⚠️ DDNS Desactivado. Ya no se comprobará la IP.${NC}"
                    sleep 2; menu_sistema ;;
                4)
                    echo -e "\n${YELLOW}▶ Ejecutando comprobación manual...${NC}"
                    if [ -f /etc/MaximusVpsMx/modules/cloudflare-ddns.sh ]; then
                        /etc/MaximusVpsMx/modules/cloudflare-ddns.sh
                        echo -e "${GREEN}✅ Comprobación completada.${NC}"
                    else
                        echo -e "${RED}❌ Script no encontrado.${NC}"
                    fi
                    sleep 2; menu_sistema ;;
                5)
                    echo -e "\n${YELLOW}▶ Últimos cambios de IP registrados:${NC}"
                    if [ -f /var/log/MaximusVpsMx/cloudflare-ddns.log ]; then
                        tail -20 /var/log/MaximusVpsMx/cloudflare-ddns.log
                    else
                        echo -e "${RED}No hay logs aún.${NC}"
                    fi
                    read -p "Presiona Enter..." ; menu_sistema ;;
                6)
                    echo -e "\n${YELLOW}▶ Configuración Actual:${NC}"
                    if [ -f /etc/MaximusVpsMx/cloudflare.conf ]; then
                        source /etc/MaximusVpsMx/cloudflare.conf
                        echo -e " Token: ${GREEN}${CF_API_TOKEN:0:8}...****${NC}"
                        echo -e " Zone:  ${GREEN}$CF_ZONE_ID${NC}"
                        echo -e " Dominio: ${GREEN}$CF_RECORD_NAME${NC}"
                        echo -e " IP Actual: ${CYAN}$(curl -s https://api.ipify.org)${NC}"
                    else
                        echo -e "${RED}No configurado aún.${NC}"
                    fi
                    read -p "Presiona Enter..." ; menu_sistema ;;
                *) menu_sistema ;;
            esac
            ;;
        99)
            echo -e "\n${RED}================ ¡¡PELIGRO!! ================${NC}"
            read -p "¿Estás 100% seguro de destruir MaximusVpsMx? [S/N]: " desc
            if [[ "$desc" == "S" || "$desc" == "s" ]]; then
                echo -e "${RED}🔥 INICIANDO PURGA MASIVA...${NC}"
                systemctl stop stunnel4 dropbear mx-proxy badvpn 2>/dev/null
                killall -9 stunnel4 dropbear python3 badvpn-udpgw 2>/dev/null
                rm -rf /etc/MaximusVpsMx
                rm -f /usr/local/bin/MX
                rm -f /etc/systemd/system/mx-proxy.service
                rm -f /etc/systemd/system/badvpn.service
                apt-get purge stunnel4 dropbear -y 2>/dev/null
                systemctl daemon-reload
                echo -e "${GREEN}✅ VUELO COMPLETADO. El servidor vuelve a ser de fábrica.${NC}"
                exit
            else
                menu_sistema
            fi
            ;;
        0) main_menu ;;
        *) menu_sistema ;;
    esac
}

