        printf " ${CYAN}Buffer: ${WHITE}%-9s ${CYAN}Cache:  ${WHITE}%-9s${NC}\n" "$RAM_BUFF" "$RAM_CACHE"
        ui_hr
        printf "    ${CYAN}ACTIVOS: ${WHITE}%-3s  ${RED}EXPIRADOS: ${WHITE}%-3s  ${CYAN}TOTAL: ${WHITE}%-3s${NC}\n" "$ACTIVA" "$EXPIRADA" "$TOTAL"
        ui_hr
        echo -e "  ${CYAN}[1]>${WHITE} USUARIOS / CUENTAS (SSH, OVPN, HYST, XUI)${NC}"
        echo -e "  ${CYAN}[2]>${WHITE} PROTOCOLOS / SERVICIOS${NC}"
        echo -e "  ${CYAN}[3]>${WHITE} AJUSTES DEL SISTEMA / FIREWALL${NC}"
        ui_subhr
        echo -e "  ${CYAN}[4]>${GREEN} MANTENIMIENTO (Actualizar o Desinstalar)${NC}"
        ui_hr
        echo -e "  ${WHITE}[0] SALIR DEL VPS     [7] SALIR SCRIPT    [8] REINICIAR${NC}"
        ui_hr
        ui_prompt " Selecciona una opción: "
        read main_opt

        case $main_opt in
            1) menu_cuentas ;;
            2) menu_protocolos ;;
            3) menu_sistema ;;
            4) menu_mantenimiento ;;
            7) clear; exit ;;
            8) echo -e "${YELLOW}🔄 Reiniciando VPS...${NC}"; reboot ;;
            0) clear; exit ;;
            *) continue ;;
        esac
    done
}

