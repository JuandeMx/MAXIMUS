                            read -p "Presiona Enter..." ;;
                        2)
                            read -p " Nombre del cliente: " c
                            if [ -z "$c" ]; then echo -e "${RED}Nombre inválido.${NC}"; sleep 2; continue; fi
                            if [ -f /etc/MaximusVpsMx/modules/install_openvpn.sh ]; then
                                bash /etc/MaximusVpsMx/modules/install_openvpn.sh --add-client "$c"
                            else
                                echo -e "${RED}❌ Módulo OpenVPN no encontrado.${NC}"
                            fi
                            read -p "Presiona Enter..." ;;
                        3)
                            read -p " Cliente a revocar: " c
                            if [ -z "$c" ]; then echo -e "${RED}Nombre inválido.${NC}"; sleep 2; continue; fi
                            if [ -f /etc/MaximusVpsMx/modules/install_openvpn.sh ]; then
                                bash /etc/MaximusVpsMx/modules/install_openvpn.sh --revoke-client "$c"
                            else
                                echo -e "${RED}❌ Módulo OpenVPN no encontrado.${NC}"
                            fi
                            read -p "Presiona Enter..." ;;
                        0) break ;;
                        *) ;;
                    esac
                done
                ;;
            3) sub_hysteria ;;
            4) sub_xui ;;
            0) return ;;
            *) ;;
        esac
    done
}

# --- PURGA NUCLEAR DEL SISTEMA ---
purgar_sistema_total() {
    clear
    echo -e "${RED}☢️ INICIANDO PURGA NUCLEAR REFORZADA v6.2 (Residual Fix)...${NC}"
    echo -e "${YELLOW}Limpieza total de servicios, binarios y reglas de red.${NC}"
    sleep 2

    # 1. Detener y Deshabilitar Servicios Systemd
    echo -e "${CYAN}[+] Fulminando servicios systemd...${NC}"
    local services=("stunnel4" "dropbear" "mx-proxy" "badvpn" "mx-slowdns" "udp-custom" "hysteria" "ws-epro" "sshd" "ssh" "mx-webpanel")
    for srv in "${services[@]}"; do
        echo -e "    - Limpiando $srv..."
        systemctl stop "$srv" 2>/dev/null
        systemctl disable "$srv" 2>/dev/null
        rm -f "/etc/systemd/system/${srv}.service" 2>/dev/null
    done

    # 2. Matar procesos por socket (Puertos críticos)
    echo -e "${CYAN}[+] Cerrando sockets ocupados...${NC}"
    local ports=("443/udp" "7300/udp" "36712/udp" "80/tcp" "443/tcp" "8080/tcp" "8082/tcp")
    for p in "${ports[@]}"; do
        fuser -k -n "$p" 2>/dev/null
    done

    # 3. Matar procesos por nombre (Fuerza bruta)
    echo -e "${CYAN}[+] Matando procesos remanentes...${NC}"
    local binaries=("stunnel4" "dropbear" "python3" "badvpn-udpgw" "udp-custom" "hysteria" "slowdns")
    for bin in "${binaries[@]}"; do
        pkill -9 "$bin" 2>/dev/null
        killall -9 "$bin" 2>/dev/null
    done

    # 4. Eliminar Binarios de Rutas Globales
    echo -e "${CYAN}[+] Eliminando binarios del sistema...${NC}"
    rm -f /usr/local/bin/badvpn-udpgw /usr/bin/badvpn-udpgw /usr/bin/hysteria /usr/local/bin/udp-custom /usr/local/bin/MX /usr/local/bin/menu /usr/local/bin/MENU 2>/dev/null

    # 5. Limpiar Firewall UFW
    echo -e "${CYAN}[+] Limpiando reglas de Firewall...${NC}"
    # Resetar UFW por completo si es purga total
    ufw --force reset > /dev/null 2>&1
    ufw allow 22/tcp > /dev/null 2>&1

    # 6. Borrar Carpetas de Configuración y Logs
    echo -e "${CYAN}[+] Borrando rastros de configuración...${NC}"
    rm -rf /etc/MaximusVpsMx /etc/hysteria /root/udp /etc/stunnel /var/log/MaximusVpsMx /etc/slowdns /etc/x-ui /usr/local/x-ui 2>/dev/null
    rm -f /etc/issue.net /etc/motd.bak 2>/dev/null

    # 7. Purga APT (Opcional pero recomendado para limpieza real)
    echo -e "${CYAN}[+] Purgando paquetes APT...${NC}"
    DEBIAN_FRONTEND=noninteractive apt-get purge stunnel4 dropbear -y 2>/dev/null
    apt-get autoremove -y 2>/dev/null

    # 8. Recargar y Finalizar
    systemctl daemon-reload
    systemctl reset-failed 2>/dev/null
    echo -e "${GREEN}✅ SISTEMA PURGADO AL 100%. EL VPS ESTÁ LIMPIO.${NC}"
    sleep 2
}

