# --- SUBMENÃ DE PROTOCOLOS ---
menu_protocolos() {
    clear
    # --- DETECCIÃN DINÃMICA DE PUERTOS Y ESTATUS (Doble VerificaciÃģn) ---
    # Solo marca [ON] si: 1) El servicio estÃĄ configurado/instalado Y 2) El puerto estÃĄ activo

    # SSH (OpenSSH) - siempre existe
    P_SSH=$(grep "^Port" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1)
    [ -z "$P_SSH" ] && P_SSH="22"
    if netstat -tuln 2>/dev/null | grep -q ":${P_SSH} "; then st_ssh="${GREEN}[ON]${NC}"; else st_ssh="${RED}[OFF]${NC}"; fi

    # Dropbear - solo si estÃĄ instalado
    if dpkg -l dropbear 2>/dev/null | grep -q "^ii"; then
        P_DROP=$(grep "DROPBEAR_PORT=" /etc/default/dropbear 2>/dev/null | cut -d= -f2 | tr -d '"' | xargs)
        [ -z "$P_DROP" ] && P_DROP="44"
        if netstat -tuln 2>/dev/null | grep -q ":${P_DROP} "; then st_drop="${GREEN}[ON]${NC}"; else st_drop="${RED}[OFF]${NC}"; fi
    else
        P_DROP="--"; st_drop="${RED}[OFF]${NC}"
    fi

    # Proxy Python - solo si el servicio existe
    if [ -f /etc/systemd/system/mx-proxy.service ]; then
        P_PROXY=$(grep "ExecStart=" /etc/systemd/system/mx-proxy.service 2>/dev/null | awk '{print $NF}')
        [ -z "$P_PROXY" ] && P_PROXY="80"
        if netstat -tuln 2>/dev/null | grep -q ":${P_PROXY} "; then st_proxy="${GREEN}[ON]${NC}"; else st_proxy="${RED}[OFF]${NC}"; fi
    else
        P_PROXY="--"; st_proxy="${RED}[OFF]${NC}"
    fi

    # Stunnel (SSL) - solo si config existe y paquete instalado
    if [ -f /etc/stunnel/stunnel.conf ] && dpkg -l stunnel4 2>/dev/null | grep -q "^ii"; then
        P_STUN=$(grep "accept =" /etc/stunnel/stunnel.conf 2>/dev/null | awk '{print $3}' | head -1)
        [ -z "$P_STUN" ] && P_STUN="443"
        if netstat -tuln 2>/dev/null | grep -q ":${P_STUN} "; then st_stun="${GREEN}[ON]${NC}"; else st_stun="${RED}[OFF]${NC}"; fi
    else
        P_STUN="--"; st_stun="${RED}[OFF]${NC}"
    fi

    # BadVPN (UDP) - solo si estÃĄ activo
    if [ -f /usr/local/bin/badvpn-udpgw ]; then
        if ps -ef | grep -q "[b]advpn-udpgw"; then
            P_BAD=$(ps -ef | grep badvpn-udpgw | grep -v grep | grep -o ":[0-9]*" | head -1 | tr -d ':')
            [ -z "$P_BAD" ] && P_BAD="7300"
            st_udp="${GREEN}[ON]${NC}"
        else
            P_BAD="--"; st_udp="${RED}[OFF]${NC}"
        fi
    else
        P_BAD="--"; st_udp="${RED}[OFF]${NC}"
    fi

    # SlowDNS
    systemctl is-active --quiet mx-slowdns && st_dns="${GREEN}[ON]${NC}" || st_dns="${RED}[OFF]${NC}"
    # WS-EPRO
    systemctl is-active --quiet ws-epro && st_ws="${GREEN}[ON]${NC}" || st_ws="${RED}[OFF]${NC}"

    # UDP-Custom - solo si el binario existe
    if [ -f /root/udp/udp-custom ]; then
        P_UDPC=$(grep -o '"listen":.*' /root/udp/config.json 2>/dev/null | grep -o '[0-9]*')
        [ -z "$P_UDPC" ] && P_UDPC="1-65535"
        if ps -ef | grep -q "[u]dp-custom"; then st_udpc="${GREEN}[ON]${NC}"; else st_udpc="${RED}[OFF]${NC}"; fi
    else
        P_UDPC="--"; st_udpc="${RED}[OFF]${NC}"
    fi

    # Hysteria v2 - solo si el binario existe
    if [ -f /etc/hysteria/hysteria ]; then
        P_HY=$(grep 'listen:' /etc/hysteria/config.yaml 2>/dev/null | grep -o '[0-9]*')
        [ -z "$P_HY" ] && P_HY="443"
        if ps -ef | grep -q "[h]ysteria"; then st_udph="${GREEN}[ON]${NC}"; else st_udph="${RED}[OFF]${NC}"; fi
    else
        P_HY="--"; st_udph="${RED}[OFF]${NC}"
    fi

    st_squid="${RED}[OFF]${NC}"; st_ovpn="${RED}[OFF]${NC}"; st_chk="${GREEN}[ON]${NC}"
    st_atken="${RED}[OFF]${NC}"; st_file="${RED}[OFF]${NC}"; st_v2ray="${RED}[OFF]${NC}"
    st_sshgo="${RED}[OFF]${NC}"; st_wg="${RED}[OFF]${NC}"

    echo -e "${RED}=======================================================${NC}"
    echo -e "${YELLOW}              ADMINISTRADOR DE PROTOCOLO${NC}"
    echo -e "${RED}=======================================================${NC}"
    echo -e " ${CYAN}SSH:${WHITE} $P_SSH  ${CYAN}DROB:${WHITE} $P_DROP  ${CYAN}PROXY:${WHITE} $P_PROXY${NC}"
    echo -e " ${CYAN}SSL:${WHITE} $P_STUN  ${CYAN}UDPG:${WHITE} $P_BAD${NC}"
    echo -e " ${CYAN}UDP-C:${WHITE} $P_UDPC  ${CYAN}HYST:${WHITE} $P_HY${NC}"
    echo -e "${RED}=======================================================${NC}"
    printf " ${CYAN}[1]>${WHITE} %-14s%b   ${CYAN}[10]>${WHITE} %-16s%b\n" "AJUSTES SSH" "$st_ssh" "SQUID" "$st_squid"
    printf " ${CYAN}[2]>${WHITE} %-14s%b   ${CYAN}[11]>${WHITE} %-16s%b\n" "DROPBEAR" "$st_drop" "OPENVPN" "$st_ovpn"
    printf " ${CYAN}[3]>${WHITE} %-14s%b   ${CYAN}[12]>${WHITE} %-16s%b\n" "SOCKS PYTHON" "$st_proxy" "CHECKUSER ONLINE" "$st_chk"
    printf " ${CYAN}[4]>${WHITE} %-14s%b   ${CYAN}[13]>${WHITE} %-16s%b\n" "STUNNEL (SSL)" "$st_stun" "ATKEN and HASH" "$st_atken"
    printf " ${CYAN}[5]>${WHITE} %-14s%b   ${CYAN}[14]>${WHITE} %-16s%b\n" "SLOWDNS" "$st_dns" "FILEBROWSER" "$st_file"
    printf " ${CYAN}[6]>${WHITE} %-14s%b   ${CYAN}[15]>${WHITE} %-16s%b\n" "WS-EPRO" "$st_ws" "V2RAY/XRAY" "$st_v2ray"
